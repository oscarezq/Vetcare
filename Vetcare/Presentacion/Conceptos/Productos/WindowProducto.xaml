<Window x:Class="Vetcare.Presentacion.Servicios.WindowProducto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ficha de Producto" Height="500" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9F9">

    <Border Padding="25">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <StackPanel Margin="0,0,0,25">
                    <TextBlock x:Name="lblTitulo" Text="NUEVO PRODUCTO" FontSize="20" FontWeight="Bold" Foreground="#1B2631"/>
                    <Rectangle Height="2" Fill="#1ABC9C" HorizontalAlignment="Left" Width="50" Margin="2,5,0,0"/>
                </StackPanel>

                <StackPanel Margin="5,0,5,15">
                    <TextBlock Text="Nombre del Producto" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNombre" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>

                <UniformGrid Columns="2" Margin="5,0,5,15">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Precio Base (€)" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPrecio" Height="32" VerticalContentAlignment="Center" Padding="8,0" 
                                 PreviewTextInput="txtPrecio_PreviewTextInput"/>
                    </StackPanel>

                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="IVA (%)" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                        <Grid Height="32">
                            <TextBox x:Name="txtIva" Text="21" VerticalContentAlignment="Center" 
                                     Padding="8,0,35,0" PreviewTextInput="txtPrecio_PreviewTextInput" LostFocus="txtIva_LostFocus"/>
                            <StackPanel HorizontalAlignment="Right" Width="30" Margin="1">
                                <RepeatButton x:Name="btnSubirIva" Content="▲" FontSize="8" Height="15" Click="btnSubirIva_Click"/>
                                <RepeatButton x:Name="btnBajarIva" Content="▼" FontSize="8" Height="15" Click="btnBajarIva_Click"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </UniformGrid>

                <StackPanel Margin="5,0,5,15">
                    <TextBlock Text="Stock Inicial / Disponible" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtStock" Height="30" Width="100" HorizontalAlignment="Left" 
                             VerticalContentAlignment="Center" Padding="5,0" PreviewTextInput="txtSoloNumeros_PreviewTextInput"/>
                </StackPanel>

                <StackPanel Margin="5,0,5,15">
                    <TextBlock Text="Descripción" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtDescripcion" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Padding="5"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="btnCancelar" Content="Cancelar" Width="90" Height="32" Margin="10,0" Click="btnCancelar_Click"/>
                <Button x:Name="btnGuardar" Content="Guardar Producto" Width="140" Height="32"
                        Background="#1ABC9C" Foreground="White" FontWeight="Bold" Click="btnGuardar_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>