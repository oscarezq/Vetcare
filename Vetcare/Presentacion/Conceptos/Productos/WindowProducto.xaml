<Window x:Class="Vetcare.Presentacion.Servicios.WindowProducto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ficha de Producto" Height="620" Width="700"
        WindowStartupLocation="CenterScreen" Background="#F8FAFC"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True" 
        SnapsToDevicePixels="True" FontFamily="Segoe UI">

    <!-- Recursos: estilos reutilizables -->
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1ABC9C"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Layout principal -->
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Contenido principal -->
        <StackPanel Grid.Row="0">

            <!-- Título -->
            <StackPanel Margin="0,0,0,30">
                <TextBlock x:Name="lblTitulo" Text="NUEVO PRODUCTO" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                <Rectangle Height="3" Fill="#E67E22" HorizontalAlignment="Left" Width="40" Margin="2,5,0,0"/>
            </StackPanel>

            <!-- Contenedor formulario -->
            <Border Background="White" CornerRadius="12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>

                    <!-- Nombre -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="NOMBRE DEL PRODUCTO" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtNombre" Style="{StaticResource ModernInput}"/>
                    </StackPanel>

                    <!-- Precio e IVA -->
                    <UniformGrid Columns="2" Margin="0,0,0,20">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="PRECIO TOTAL (€)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtPrecio" Style="{StaticResource ModernInput}" 
                                     PreviewTextInput="TxtPrecio_PreviewTextInput"/>
                        </StackPanel>

                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="IVA (%)" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cmbIva" Height="38" VerticalContentAlignment="Center" 
                                      Padding="12,0" Background="White" BorderBrush="#E2E8F0">
                                <ComboBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </ComboBox.Resources>

                                <!-- Opciones de IVA -->
                                <ComboBoxItem Content="21" IsSelected="True"/>
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="4"/>
                            </ComboBox>
                        </StackPanel>
                    </UniformGrid>

                    <!-- Stock -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="INVENTARIO / STOCK" Style="{StaticResource FieldLabel}"/>

                        <Grid HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Caja de stock -->
                            <Border x:Name="borderStock" 
                                    Background="White" 
                                    CornerRadius="8" 
                                    BorderBrush="#E2E8F0" 
                                    BorderThickness="1"
                                    Width="160" 
                                    Height="42">

                                <Grid Margin="12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icono -->
                                    <TextBlock Text="📦" 
                                               VerticalAlignment="Center" 
                                               FontSize="14"
                                               Margin="0,0,8,0" 
                                               Opacity="0.6"/>

                                    <!-- Input stock -->
                                    <TextBox x:Name="txtStock" 
                                             Grid.Column="1"
                                             Text="0"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             VerticalContentAlignment="Center"
                                             HorizontalContentAlignment="Left"
                                             FontSize="16" 
                                             Foreground="#334155"
                                             PreviewTextInput="TxtSoloNumeros_PreviewTextInput"/>
                                </Grid>
                            </Border>

                            <!-- Botón ajustar stock -->
                            <Button x:Name="btnAjustarStock" 
                                    Visibility="Collapsed"
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Padding="20,0"
                                    Height="42"
                                    Background="#0284C7" 
                                    Foreground="White" 
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Click="BtnAjustarStock_Click">

                                <Button.Content>
                                    <TextBlock Text="AJUSTAR STOCK" VerticalAlignment="Center"/>
                                </Button.Content>

                                <!-- Estilo botón -->
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15,0"/>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="btnBorder" Property="Background" Value="#0369A1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Info stock -->
                        <TextBlock x:Name="lblInfoStock" 
                                   Text="* Indique el stock inicial del producto." 
                                   FontSize="10" Foreground="#94A3B8" Margin="5,6,0,0"/>
                    </StackPanel>

                    <!-- Descripción -->
                    <StackPanel>
                        <TextBlock Text="DESCRIPCIÓN" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtDescripcion" Style="{StaticResource ModernInput}" 
                                 Height="80" TextWrapping="Wrap" AcceptsReturn="True" 
                                 Padding="12,10" VerticalContentAlignment="Top"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Botones finales -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">

            <!-- Cancelar -->
            <Button x:Name="btnCancelar" Content="Cancelar" Width="100" Height="42"
                    Click="BtnCancelar_Click" Cursor="Hand" Background="Transparent" 
                    Foreground="#64748B" FontWeight="SemiBold" BorderThickness="0"/>

            <!-- Guardar -->
            <Button x:Name="btnGuardar" Content="Guardar Producto" Width="160" Height="42"
                    Background="#E67E22" Foreground="White" FontWeight="Bold" IsDefault="True"
                    Click="BtnGuardar_Click" Cursor="Hand" BorderThickness="0" Margin="10,0,0,0">

                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>

            </Button>
        </StackPanel>
    </Grid>
</Window>