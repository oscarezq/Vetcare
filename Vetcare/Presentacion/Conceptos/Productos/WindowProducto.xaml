<Window x:Class="Vetcare.Presentacion.Servicios.WindowProducto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ficha de Producto" Height="620" Width="700"
        WindowStartupLocation="CenterScreen" Background="#F8FAFC"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True" 
        SnapsToDevicePixels="True" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1ABC9C"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IvaButtonStyle" TargetType="RepeatButton">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E8F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Margin="0,0,0,30">
                <TextBlock x:Name="lblTitulo" Text="NUEVO PRODUCTO" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                <Rectangle Height="3" Fill="#E67E22" HorizontalAlignment="Left" Width="40" Margin="2,5,0,0"/>
            </StackPanel>

            <Border Background="White" CornerRadius="12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="NOMBRE DEL PRODUCTO" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtNombre" Style="{StaticResource ModernInput}"/>
                    </StackPanel>

                    <UniformGrid Columns="2" Margin="0,0,0,20">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="PRECIO TOTAL (€)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtPrecio" Style="{StaticResource ModernInput}" 
                                     PreviewTextInput="txtPrecio_PreviewTextInput"/>
                        </StackPanel>

                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="IVA (%)" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cmbIva" Height="38" VerticalContentAlignment="Center" 
              Padding="12,0" Background="White" BorderBrush="#E2E8F0">
                                <ComboBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBoxItem Content="21" IsSelected="True"/>
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="4"/>
                            </ComboBox>
                        </StackPanel>
                    </UniformGrid>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="STOCK DISPONIBLE" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtStock" Style="{StaticResource ModernInput}" Width="120" 
                                 HorizontalAlignment="Left" PreviewTextInput="txtSoloNumeros_PreviewTextInput"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="DESCRIPCIÓN" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtDescripcion" Style="{StaticResource ModernInput}" 
                                 Height="80" TextWrapping="Wrap" AcceptsReturn="True" 
                                 Padding="12,10" VerticalContentAlignment="Top"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnCancelar" Content="Cancelar" Width="100" Height="42"
                    Click="btnCancelar_Click" Cursor="Hand" Background="Transparent" 
                    Foreground="#64748B" FontWeight="SemiBold" BorderThickness="0"/>

            <Button x:Name="btnGuardar" Content="Guardar Producto" Width="160" Height="42"
                    Background="#E67E22" Foreground="White" FontWeight="Bold" IsDefault="True"
                    Click="btnGuardar_Click" Cursor="Hand" BorderThickness="0" Margin="10,0,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>