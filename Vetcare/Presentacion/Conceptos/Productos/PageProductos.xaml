<Page x:Class="Vetcare.Presentacion.Servicios.PageProductos"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1100"
      Title="Gestión de Productos">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- SECCIÓN DE FILTROS -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderBrush="#D5DBDB" BorderThickness="1">
            <StackPanel>

                <!-- TÍTULO FILTROS -->
                <TextBlock Text="BUSCAR POR CAMPO" FontSize="11" FontWeight="Bold" Foreground="#E67E22" Margin="5,0,0,10"/>

                <UniformGrid Columns="4" Margin="0,0,0,15">

                    <UniformGrid.Resources>

                        <Style TargetType="Control" x:Key="ControlBaseStyle">
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>

                        <Style TargetType="TextBox" BasedOn="{StaticResource ControlBaseStyle}">
                            <Setter Property="Padding" Value="5,0"/>
                        </Style>

                        <Style TargetType="ComboBox" BasedOn="{StaticResource ControlBaseStyle}"/>

                    </UniformGrid.Resources>

                    <!-- FILTRO NOMBRE -->
                    <StackPanel Margin="5,2">
                        <TextBlock Text="Nombre" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtBuscaNombre" TextChanged="Filtro_Changed"/>
                    </StackPanel>

                    <!-- FILTRO PRECIO MÍNIMO -->
                    <StackPanel Margin="5,2">
                        <TextBlock Text="Precio Mín. (€)" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtPrecioMin" TextChanged="Filtro_Changed"/>
                    </StackPanel>

                    <!-- FILTRO PRECIO MÁXIMO -->
                    <StackPanel Margin="5,2">
                        <TextBlock Text="Precio Máx. (€)" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtPrecioMax" TextChanged="Filtro_Changed"/>
                    </StackPanel>

                    <!-- FILTRO ESTADO -->
                    <StackPanel Margin="5,2">
                        <TextBlock Text="Estado" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <ComboBox x:Name="cbBuscaEstado" SelectionChanged="Filtro_Changed">
                            <ComboBoxItem Content="Todos"/>
                            <ComboBoxItem Content="Activo" IsSelected="True"/>
                            <ComboBoxItem Content="Inactivo"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- FILTRO STOCK MÍNIMO -->
                    <StackPanel Margin="5,2">
                        <TextBlock Text="Stock Mín." FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtStockMin" TextChanged="Filtro_Changed"/>
                    </StackPanel>

                    <!-- FILTRO STOCK MÁXIMO -->
                    <StackPanel Margin="5,2">
                        <TextBlock Text="Stock Máx." FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtStockMax" TextChanged="Filtro_Changed"/>
                    </StackPanel>

                </UniformGrid>

                <Separator Background="#EBEDEF" Margin="5,5,5,15"/>

                <!-- ORDENACIÓN -->
                <StackPanel Orientation="Horizontal">

                    <!-- LABEL ORDEN -->
                    <TextBlock Text="ORDENAR POR:" FontSize="11" FontWeight="Bold" Foreground="#2E86C1"
                               VerticalAlignment="Center" Margin="5,0,15,0"/>

                    <!-- COMBO ORDENAR -->
                    <ComboBox x:Name="cbOrdenarPor" Width="150" Height="28"
                              VerticalContentAlignment="Center" SelectionChanged="Filtro_Changed">

                        <ComboBoxItem Content="Nombre" IsSelected="True"/>
                        <ComboBoxItem Content="Precio"/>
                        <ComboBoxItem Content="Stock"/>

                    </ComboBox>

                    <!-- ORDEN ASC/DESC -->
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">

                        <RadioButton x:Name="rbAsc" Content="Ascendente" IsChecked="True"
                                     Margin="0,0,15,0" Checked="Filtro_Changed"/>

                        <RadioButton x:Name="rbDesc" Content="Descendente" Checked="Filtro_Changed"/>

                    </StackPanel>

                    <!-- LIMPIAR FILTROS -->
                    <Button Content="Limpiar Filtros"
                            Margin="30,0,0,0"
                            Padding="15,0"
                            Click="BtnLimpiar_Click"
                            Height="28"
                            Cursor="Hand"
                            Background="#F4F6F7"
                            BorderBrush="#D5DBDB"/>

                </StackPanel>

            </StackPanel>
        </Border>

        <!-- SECCIÓN LISTADO -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15"
                BorderBrush="#D5DBDB" BorderThickness="1">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,15">

                    <!-- TÍTULO -->
                    <TextBlock Text="Catálogo de Productos"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#2C3E50"
                               VerticalAlignment="Center"/>

                    <!-- BOTÓN NUEVO -->
                    <Button DockPanel.Dock="Right"
                            x:Name="btnNuevoProducto"
                            Content="+ Nuevo Producto"
                            Click="BtnNuevoProducto_Click"
                            Background="#27AE60"
                            Foreground="White"
                            FontWeight="Bold"
                            Padding="20,0"
                            Height="38"
                            Cursor="Hand"
                            BorderThickness="0">

                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>

                    </Button>

                </DockPanel>

                <!-- DATAGRID PRINCIPAL -->
                <DataGrid x:Name="dgProductos"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          MouseDoubleClick="DgProductos_MouseDoubleClick"
                          Background="White"
                          FontSize="14"
                          RowHeight="50"
                          ColumnHeaderHeight="40"
                          CanUserSortColumns="False"
                          CanUserReorderColumns="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          CanUserResizeColumns="False">

                    <DataGrid.Resources>

                        <!-- SELECCIÓN -->
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>

                        <!-- CABECERA -->
                        <Style x:Key="HeaderStyleComun" TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9F9"/>
                            <Setter Property="Foreground" Value="#566573"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E67E22"/>
                        </Style>

                        <!-- CELDAS -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyleComun}"/>

                    </DataGrid.Resources>

                    <!-- FILAS -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="#EBEDEF"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>

                            <Style.Triggers>

                                <!-- HOVER -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F4F6F7"/>
                                </Trigger>

                                <!-- SELECCIÓN -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF5FB"/>
                                    <Setter Property="Foreground" Value="#2E86C1"/>
                                </Trigger>

                            </Style.Triggers>

                        </Style>
                    </DataGrid.RowStyle>

                    <!-- COLUMNAS -->
                    <DataGrid.Columns>

                        <!-- ESTADO -->
                        <DataGridTemplateColumn Header="ESTADO" Width="100">

                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyleComun}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>

                            <DataGridTemplateColumn.CellTemplate>

                                <DataTemplate>

                                    <Border x:Name="brdEstado" CornerRadius="10" Padding="8,3" HorizontalAlignment="Center">
                                        <TextBlock x:Name="txtEstado" FontSize="11" FontWeight="Bold" TextAlignment="Center"/>
                                    </Border>

                                    <!-- ESTADO VISUAL -->
                                    <DataTemplate.Triggers>

                                        <!-- ACTIVO -->
                                        <DataTrigger Binding="{Binding Activo}" Value="True">
                                            <Setter TargetName="brdEstado" Property="Background" Value="#EAFAF1"/>
                                            <Setter TargetName="txtEstado" Property="Foreground" Value="#27AE60"/>
                                            <Setter TargetName="txtEstado" Property="Text" Value="Activo"/>
                                        </DataTrigger>

                                        <!-- INACTIVO -->
                                        <DataTrigger Binding="{Binding Activo}" Value="False">
                                            <Setter TargetName="brdEstado" Property="Background" Value="#FDEDEC"/>
                                            <Setter TargetName="txtEstado" Property="Foreground" Value="#CB4335"/>
                                            <Setter TargetName="txtEstado" Property="Text" Value="Inactivo"/>
                                        </DataTrigger>

                                    </DataTemplate.Triggers>

                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                        <!-- PRODUCTO -->
                        <DataGridTemplateColumn Header="PRODUCTO" Width="1.5*">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <TextBlock VerticalAlignment="Center">

                                        <!-- LINK DETALLE -->
                                        <Hyperlink Click="BtnVerDetalle_Click"
                                                   Foreground="#2E86C1"
                                                   TextDecorations="{x:Null}">

                                            <Run Text="{Binding Nombre}" FontWeight="SemiBold"/>

                                        </Hyperlink>

                                    </TextBlock>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                        <!-- DESCRIPCIÓN -->
                        <DataGridTextColumn Header="DESCRIPCIÓN" Binding="{Binding Descripcion}" Width="2*"/>

                        <!-- PRECIO SIN IVA -->
                        <DataGridTextColumn Header="PRECIO SIN IVA"
                                             Binding="{Binding PrecioSinIva, StringFormat=\{0:N2\} €}"
                                             Width="150"/>

                        <!-- IVA -->
                        <DataGridTextColumn Header="IVA"
                                             Binding="{Binding IvaPorcentaje, StringFormat=\{0\}%}"
                                             Width="100"/>

                        <!-- PRECIO CON IVA -->
                        <DataGridTemplateColumn Header="PRECIO CON IVA" Width="150">

                            <DataGridTemplateColumn.CellTemplate>

                                <DataTemplate>

                                    <TextBlock Text="{Binding Precio, StringFormat=\{0:N2\} €}"
                                               FontWeight="Bold"
                                               Foreground="#2E86C1"
                                               VerticalAlignment="Center"/>

                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                        <!-- STOCK -->
                        <DataGridTextColumn Header="STOCK" Binding="{Binding Stock}" Width="80">

                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#27AE60"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>

                        </DataGridTextColumn>

                        <!-- ACCIONES -->
                        <DataGridTemplateColumn Header="ACCIONES" Width="150">

                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyleComun}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>

                            <DataGridTemplateColumn.CellTemplate>

                                <DataTemplate>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                        <!-- VER -->
                                        <Button x:Name="btnDetalles"
                                                Content="👁"
                                                ToolTip="Ver Detalle"
                                                Click="BtnVerDetalle_Click"
                                                Margin="2,0"
                                                Background="#EBF5FB"
                                                Foreground="#2E86C1"
                                                Width="35"
                                                Height="30"
                                                BorderBrush="#AED6F1"
                                                Cursor="Hand"/>

                                        <!-- EDITAR -->
                                        <Button x:Name="btnEditar"
                                                Content="✎"
                                                ToolTip="Editar"
                                                Click="BtnEditarProducto_Click"
                                                Margin="2,0"
                                                Background="#EBF5FB"
                                                Foreground="#2E86C1"
                                                Width="35"
                                                Height="30"
                                                BorderBrush="#AED6F1"
                                                Cursor="Hand">

                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Activo}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>

                                        </Button>

                                        <!-- ELIMINAR -->
                                        <Button x:Name="btnEliminar"
                                                Content="❌"
                                                ToolTip="Eliminar"
                                                Click="BtnEliminarProducto_Click"
                                                Margin="2,0"
                                                Background="#FDEDEC"
                                                Foreground="#CB4335"
                                                Width="35"
                                                Height="30"
                                                BorderBrush="#FADBD8"
                                                Cursor="Hand">

                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Activo}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>

                                        </Button>

                                        <!-- REACTIVAR -->
                                        <Button x:Name="btnReactivar"
                                                Content="🔁"
                                                ToolTip="Reactivar"
                                                Click="BtnReactivarProducto_Click"
                                                Margin="2,0"
                                                Background="#EBF5FB"
                                                Foreground="#27AE60"
                                                Width="35"
                                                Height="30"
                                                BorderBrush="#A9DFBF"
                                                Cursor="Hand">

                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Activo}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>

                                        </Button>

                                    </StackPanel>

                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Border>

    </Grid>
</Page>