<Page x:Class="Vetcare.Presentacion.Citas.PageCitas"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1100"
      Title="Gestión de Citas">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderBrush="#D5DBDB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="BUSCAR POR CAMPO" FontSize="11" FontWeight="Bold" Foreground="#E67E22" Margin="5,0,0,10"/>

                <UniformGrid Columns="4" Margin="0,0,0,15">

                    <!-- Mascota -->
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Mascota" FontSize="10" Foreground="#7F8C8D"/>
                        <TextBox x:Name="txtBuscaPaciente" Height="25" TextChanged="FiltroCita_Changed"/>
                    </StackPanel>

                    <!-- Veterinario -->
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Veterinario" FontSize="10" Foreground="#7F8C8D"/>
                        <TextBox x:Name="txtBuscaVeterinario" Height="25" TextChanged="FiltroCita_Changed"/>
                    </StackPanel>

                    <!-- Dueño -->
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Dueño" FontSize="10" Foreground="#7F8C8D"/>
                        <TextBox x:Name="txtBuscaDueno" Height="25" TextChanged="FiltroCita_Changed"/>
                    </StackPanel>

                    <!-- Estado -->
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Estado" FontSize="10" Foreground="#7F8C8D"/>
                        <ComboBox x:Name="cbBuscaEstado" Height="25" SelectionChanged="FiltroCita_Changed">
                            <ComboBoxItem Content="Todos" IsSelected="True"/>
                            <ComboBoxItem Content="Pendiente"/>
                            <ComboBoxItem Content="Completada"/>
                            <ComboBoxItem Content="Cancelada"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Fecha Desde -->
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Fecha - Desde" FontSize="10" Foreground="#7F8C8D"/>
                        <DatePicker x:Name="dtpFechaDesde" Height="25" SelectedDateChanged="FiltroCita_Changed"/>
                    </StackPanel>

                    <!-- Fecha Hasta -->
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Fecha - Hasta" FontSize="10" Foreground="#7F8C8D"/>
                        <DatePicker x:Name="dtpFechaHasta" Height="25" SelectedDateChanged="FiltroCita_Changed"/>
                    </StackPanel>

                    <!-- Hora Desde -->
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Hora - Desde (HH:mm)" FontSize="10" Foreground="#7F8C8D"/>
                        <TextBox x:Name="txtHoraDesde" Height="25" TextChanged="FiltroCita_Changed"/>
                    </StackPanel>

                    <!-- Hora Hasta -->
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Hora - Hasta (HH:mm)" FontSize="10" Foreground="#7F8C8D"/>
                        <TextBox x:Name="txtHoraHasta" Height="25" TextChanged="FiltroCita_Changed"/>
                    </StackPanel>

                </UniformGrid>

                <Separator Background="#EBEDEF" Margin="5,5,5,15"/>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ORDENAR POR:" FontSize="11" FontWeight="Bold" Foreground="#2E86C1" VerticalAlignment="Center" Margin="5,0,15,0"/>

                    <ComboBox x:Name="cbOrdenarPor" Width="150" Height="25" SelectionChanged="FiltroCita_Changed">
                        <ComboBoxItem Content="Fecha" IsSelected="True"/>
                        <ComboBoxItem Content="Mascota"/>
                        <ComboBoxItem Content="Veterinario"/>
                        <ComboBoxItem Content="Estado"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                        <RadioButton x:Name="rbAsc" Content="Ascendente" IsChecked="True" Margin="0,0,15,0" Checked="FiltroCita_Changed"/>
                        <RadioButton x:Name="rbDesc" Content="Descendente" Checked="FiltroCita_Changed"/>
                    </StackPanel>

                    <Button Content="Limpiar Filtros"
                    Margin="30,0,0,0"
                    Padding="15,0"
                    Click="btnLimpiar_Click"
                    Height="25"
                    Cursor="Hand"
                    Background="#F4F6F7"
                    BorderBrush="#D5DBDB"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" BorderBrush="#D5DBDB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,15">
                    <TextBlock Text="Agenda de Citas" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>

                    <Button DockPanel.Dock="Right" x:Name="btnNuevaCita" Content="+ Agendar Cita" Click="btnNuevaCita_Click"
                            Background="#27AE60" Foreground="White" FontWeight="Bold" Padding="20,0" Height="38" Cursor="Hand" BorderThickness="0" Margin="10,0,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </DockPanel>

                <DataGrid x:Name="dgCitas" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          GridLinesVisibility="None" BorderThickness="0" HeadersVisibility="Column"
                          Background="White" FontSize="14" RowHeight="50" ColumnHeaderHeight="40">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9F9"/>
                            <Setter Property="Foreground" Value="#566573"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="20,0,10,0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E67E22"/>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="20,0,10,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="Transparent" BorderThickness="0" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="#EBEDEF"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F4F6F7"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF5FB"/>
                                    <Setter Property="Foreground" Value="#2E86C1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="FECHA / HORA" 
                        Binding="{Binding FechaHora, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" 
                        Width="150"/>

                        <DataGridTemplateColumn Header="MASCOTA" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NombreMascota}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2E86C1"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="DUEÑO" Binding="{Binding NombreDueno}" Width="1.5*"/>

                        <DataGridTextColumn Header="VETERINARIO" Binding="{Binding InfoVeterinario}" Width="2*"/>

                        <DataGridTemplateColumn Header="ESTADO" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" Background="#F4F6F7" Margin="5,0">
                                        <TextBlock Text="{Binding Estado}" FontSize="12" HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="ACCIONES" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="✎" ToolTip="Editar" Click="btnEditarCita_Click" Margin="2,0" 
                            Background="#EBF5FB" Foreground="#2E86C1" Width="32" Height="28" BorderBrush="#AED6F1"/>
                                        <Button Content="🗑" ToolTip="Eliminar" Click="btnEliminarCita_Click" Margin="2,0" 
                            Background="#FDEDEC" Foreground="#CB4335" Width="32" Height="28" BorderBrush="#FADBD8"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>