<Page x:Class="Vetcare.Presentacion.Citas.PageCitas"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:util="clr-namespace:Vetcare.Entidades"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1100"
      Title="Gestión de Citas">

    <!-- Recursos de la página (estilos reutilizables) -->
    <Page.Resources>

        <!-- Estilo para botones tipo "segmento" (tipo pestañas) -->
        <Style x:Key="SegmentedButtonStyle" TargetType="RadioButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="BorderThickness" Value="0"/>

            <!-- Plantilla visual personalizada -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <!-- Cambios visuales según estado -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#E67E22"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid Margin="20">

        <!-- Definición de filas: filtros arriba y tabla abajo -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- SECCIÓN DE FILTROS -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,15"
                BorderBrush="#D5DBDB"
                BorderThickness="1">

            <StackPanel>

                <!-- Título de filtros -->
                <TextBlock Text="BUSCAR POR CAMPO"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="#E67E22"
                           Margin="5,0,0,10"/>

                <!-- Filtros en grid -->
                <UniformGrid Columns="4" Margin="0,0,0,15">

                    <!-- Estilos locales para controles -->
                    <UniformGrid.Resources>

                        <Style TargetType="Control" x:Key="ControlBaseStyle">
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>

                        <Style TargetType="TextBox" BasedOn="{StaticResource ControlBaseStyle}">
                            <Setter Property="Padding" Value="5,0"/>
                        </Style>

                        <Style TargetType="ComboBox" BasedOn="{StaticResource ControlBaseStyle}"/>
                        <Style TargetType="DatePicker" BasedOn="{StaticResource ControlBaseStyle}"/>

                    </UniformGrid.Resources>

                    <!-- Filtro por mascota -->
                    <StackPanel Margin="5,2">
                        <TextBlock Text="Mascota" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtBuscaPaciente" TextChanged="FiltroCita_Changed"/>
                    </StackPanel>

                    <!-- Filtro por veterinario -->
                    <StackPanel Margin="5,2">
                        <TextBlock Text="Veterinario" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtBuscaVeterinario" TextChanged="FiltroCita_Changed"/>
                    </StackPanel>

                    <!-- Filtro por dueño -->
                    <StackPanel Margin="5,2">
                        <TextBlock Text="Dueño" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtBuscaDueno" TextChanged="FiltroCita_Changed"/>
                    </StackPanel>

                    <!-- Filtro por estado -->
                    <StackPanel Margin="5,2">
                        <TextBlock Text="Estado" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <ComboBox x:Name="cbBuscaEstado" SelectionChanged="FiltroCita_Changed">
                            <ComboBoxItem Content="Todos"/>
                            <ComboBoxItem Content="Pendiente" IsSelected="True"/>
                            <ComboBoxItem Content="Completada"/>
                            <ComboBoxItem Content="Cancelada"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Filtro fecha desde -->
                    <StackPanel Margin="5,2">
                        <TextBlock Text="Fecha - Desde" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <DatePicker x:Name="dtpFechaDesde" SelectedDateChanged="FiltroCita_Changed"/>
                    </StackPanel>

                    <!-- Filtro fecha hasta -->
                    <StackPanel Margin="5,2">
                        <TextBlock Text="Fecha - Hasta" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <DatePicker x:Name="dtpFechaHasta" SelectedDateChanged="FiltroCita_Changed"/>
                    </StackPanel>

                </UniformGrid>

                <Separator Background="#EBEDEF" Margin="5,5,5,15"/>

                <!-- Ordenación -->
                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="ORDENAR POR:"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#2E86C1"
                               VerticalAlignment="Center"
                               Margin="5,0,15,0"/>

                    <ComboBox x:Name="cbOrdenarPor"
                              Width="150"
                              Height="28"
                              VerticalContentAlignment="Center"
                              SelectionChanged="FiltroCita_Changed">

                        <ComboBoxItem Content="Fecha" IsSelected="True"/>
                        <ComboBoxItem Content="Mascota"/>
                        <ComboBoxItem Content="Veterinario"/>
                        <ComboBoxItem Content="Estado"/>

                    </ComboBox>

                    <!-- Orden asc/desc -->
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                        <RadioButton x:Name="rbAsc" Content="Ascendente" IsChecked="True" Margin="0,0,15,0" Checked="FiltroCita_Changed"/>
                        <RadioButton x:Name="rbDesc" Content="Descendente" Checked="FiltroCita_Changed"/>
                    </StackPanel>

                    <!-- Botón limpiar filtros -->
                    <Button Content="Limpiar Filtros"
                            Margin="30,0,0,0"
                            Padding="15,0"
                            Click="BtnLimpiar_Click"
                            Height="28"
                            Cursor="Hand"
                            Background="#F4F6F7"
                            BorderBrush="#D5DBDB"/>

                </StackPanel>

            </StackPanel>
        </Border>

        <!-- SECCIÓN LISTADO -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="15"
                BorderBrush="#D5DBDB"
                BorderThickness="1">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- CABECERA -->
                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,15">

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <TextBlock Text="Agenda de Citas"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,20,0"/>

                        <!-- Selector de vista -->
                        <Border x:Name="brdSelectorVista"
                                Background="#F2F4F4"
                                CornerRadius="8"
                                Padding="3"
                                BorderBrush="#D5DBDB"
                                BorderThickness="1">

                            <StackPanel Orientation="Horizontal">

                                <RadioButton x:Name="rbMisCitas"
                                             Content="Mis Citas"
                                             IsChecked="True"
                                             GroupName="VistaCitas"
                                             Checked="FiltroCita_Changed"
                                             Style="{StaticResource SegmentedButtonStyle}"/>

                                <RadioButton x:Name="rbTodasCitas"
                                             Content="Todas las Citas"
                                             GroupName="VistaCitas"
                                             Checked="FiltroCita_Changed"
                                             Style="{StaticResource SegmentedButtonStyle}"/>

                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <!-- Botón nueva cita -->
                    <Button DockPanel.Dock="Right"
                            x:Name="btnNuevaCita"
                            Content="+ Agendar Cita"
                            Click="BtnNuevaCita_Click"
                            Background="#27AE60"
                            Foreground="White"
                            FontWeight="Bold"
                            Padding="20,0"
                            Height="38"
                            Cursor="Hand"
                            BorderThickness="0">

                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>

                    </Button>

                </DockPanel>

                <!-- TABLA -->
                <DataGrid x:Name="dgCitas"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          CanUserSortColumns="False"
                          CanUserReorderColumns="False"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          MouseDoubleClick="DgCitas_MouseDoubleClick"
                          CanUserResizeColumns="False"
                          Background="White"
                          FontSize="14"
                          RowHeight="50"
                          ColumnHeaderHeight="40">

                    <DataGrid.Resources>

                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>

                        <!-- Estilo cabeceras -->
                        <Style x:Key="HeaderStyleComun" TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9F9"/>
                            <Setter Property="Foreground" Value="#566573"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E67E22"/>
                        </Style>

                        <!-- Estilo celdas -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyleComun}"/>

                    </DataGrid.Resources>

                    <!-- Estilo filas -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="#EBEDEF"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F4F6F7"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF5FB"/>
                                    <Setter Property="Foreground" Value="#2E86C1"/>
                                </Trigger>
                            </Style.Triggers>

                        </Style>
                    </DataGrid.RowStyle>

                    <!-- COLUMNAS -->
                    <DataGrid.Columns>

                        <!-- ESTADO -->
                        <DataGridTemplateColumn Header="ESTADO" Width="120">

                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyleComun}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <!-- Estado visual -->
                                    <Border x:Name="brdEstado"
                                            CornerRadius="10"
                                            Padding="8,3"
                                            HorizontalAlignment="Center">

                                        <TextBlock x:Name="txtEstado"
                                                   Text="{Binding Estado}"
                                                   FontSize="11"
                                                   FontWeight="Bold"/>

                                    </Border>

                                    <!-- Colores según estado -->
                                    <DataTemplate.Triggers>

                                        <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                            <Setter TargetName="brdEstado" Property="Background" Value="#FEF9E7"/>
                                            <Setter TargetName="txtEstado" Property="Foreground" Value="#F1C40F"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding Estado}" Value="Completada">
                                            <Setter TargetName="brdEstado" Property="Background" Value="#EAFAF1"/>
                                            <Setter TargetName="txtEstado" Property="Foreground" Value="#27AE60"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding Estado}" Value="Cancelada">
                                            <Setter TargetName="brdEstado" Property="Background" Value="#FDEDEC"/>
                                            <Setter TargetName="txtEstado" Property="Foreground" Value="#E74C3C"/>
                                        </DataTrigger>

                                    </DataTemplate.Triggers>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="FECHA / HORA"
                                             Binding="{Binding FechaHora, StringFormat=\{0:dd/MM/yyyy HH:mm\}}"
                                             Width="1.5*"/>

                        <DataGridTemplateColumn Header="MASCOTA" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NombreMascota}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="#2E86C1"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="DUEÑO" Binding="{Binding NombreDueno}" Width="1.5*"/>
                        <DataGridTextColumn Header="VETERINARIO" Binding="{Binding NombreVeterinario}" Width="1.5*"/>

                        <!-- ACCIONES -->
                        <DataGridTemplateColumn Header="ACCIONES" Width="150">

                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyleComun}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                        <Button Content="👁"
                                                ToolTip="Ver Detalle"
                                                Click="BtnVerDetalle_Click"
                                                Margin="2,0"
                                                Background="#EBF5FB"
                                                Foreground="#2E86C1"
                                                Width="35"
                                                Height="30"
                                                BorderBrush="#AED6F1"
                                                Cursor="Hand"/>

                                        <!-- Botón editar -->
                                        <Button Content="✎"
                                                ToolTip="Editar"
                                                Click="BtnEditarCita_Click"
                                                Margin="2,0"
                                                Background="#EBF5FB"
                                                Foreground="#2E86C1"
                                                Width="35"
                                                Height="30"
                                                BorderBrush="#AED6F1"
                                                Cursor="Hand">

                                            <Button.Style>
                                                <Style TargetType="Button">

                                                    <Setter Property="Visibility" Value="Collapsed"/>

                                                    <!-- Solo visible si está pendiente -->
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>

                                                </Style>
                                            </Button.Style>

                                        </Button>

                                    </StackPanel>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>
        </Border>

    </Grid>
</Page>