<UserControl x:Class="Vetcare.Presentacion.Mascotas.UC_HistorialClinico"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="900"
             Background="White" FontFamily="Segoe UI">

    <!-- CONTENEDOR PRINCIPAL -->
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- CABECERA CON TÍTULO Y BOTÓN -->
        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,30">

            <!-- BLOQUE DE TÍTULOS -->
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Historial Clínico" FontSize="28" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Registros médicos y consultas previas" FontSize="12" Foreground="#95A5A6" Margin="2,0,0,0"/>
            </StackPanel>

            <!-- BOTÓN DESCARGAR PDF -->
            <Button DockPanel.Dock="Right" 
                    x:Name="btnImprimir"
                    Click="BtnImprimir_Click"
                    Background="#3498DB" 
                    Foreground="White" 
                    Padding="15,5" 
                    Cursor="Hand"
                    Height="40"
                    VerticalAlignment="Bottom">

                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <StackPanel Orientation="Horizontal" Margin="20,0">
                                <TextBlock Text="Descargar PDF" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DockPanel>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Row="1">

            <!-- TABLA DE HISTORIAL -->
            <DataGrid x:Name="dgHistorial" 
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      HeadersVisibility="Column"  CanUserSortColumns="False"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F2F2F2"
                      Background="Transparent" BorderThickness="0"
                      FontSize="15" RowHeight="55" CanUserReorderColumns="False"
                      SelectionMode="Single" SelectionUnit="FullRow" CanUserResizeColumns="False">

                <!-- ESTILOS DEL DATAGRID -->
                <DataGrid.Resources>

                    <!-- ESTILO DE CELDAS -->
                    <Style TargetType="DataGridCell">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                        <ContentPresenter VerticalAlignment="Center" Margin="10,0"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>

                        <!-- EFECTO SELECCIÓN -->
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EBF5FB"/>
                                <Setter Property="Foreground" Value="#2E86C1"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <!-- ESTILO DE CABECERAS -->
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,0,10,10"/>
                        <Setter Property="Foreground" Value="#95A5A6"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#F2F2F2"/>
                    </Style>
                </DataGrid.Resources>

                <!-- DEFINICIÓN DE COLUMNAS -->
                <DataGrid.Columns>

                    <!-- COLUMNA FECHA -->
                    <DataGridTemplateColumn Header="FECHA" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center">
                                    <Hyperlink Click="BtnVerDetalle_Click" Foreground="#3498DB" FontWeight="Bold" TextDecorations="None">
                                        <Run Text="{Binding FechaHora, StringFormat=dd/MM/yyyy HH:mm}"/>
                                    </Hyperlink>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- COLUMNA MOTIVO -->
                    <DataGridTextColumn Header="MOTIVO DE CONSULTA" 
                                        Binding="{Binding Motivo}" 
                                        Width="*">

                        <!-- ESTILO DEL TEXTO -->
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="Foreground" Value="#34495E"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- COLUMNA BOTÓN DETALLES -->
                    <DataGridTemplateColumn Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <!-- BOTÓN VER DETALLES -->
                                <Button Content="Ver detalles" 
                                        Click="BtnVerDetalle_Click"
                                        Background="#1ABC9C" 
                                        Foreground="White"
                                        FontWeight="SemiBold"
                                        Height="30"
                                        Cursor="Hand">

                                    <!-- TEMPLATE BOTÓN -->
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>

                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>

            <!-- PANEL CUANDO NO HAY DATOS -->
            <StackPanel x:Name="pnlSinDatos" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Center" 
                        Visibility="Collapsed">

                <!-- ICONO -->
                <TextBlock Text="📋" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="#D5DBDB"/>

                <!-- MENSAJES -->
                <TextBlock Text="No hay registros todavía" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#ABB2B9" 
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Esta mascota aún no tiene consultas grabadas en su historial." 
                           FontSize="14" 
                           Foreground="#D5DBDB" 
                           HorizontalAlignment="Center" 
                           Margin="0,5,0,0"/>

                <TextBlock Text="Las nuevas consultas aparecerán aquí automáticamente." 
                           FontSize="12" 
                           Foreground="#D5DBDB" 
                           HorizontalAlignment="Center" 
                           FontStyle="Italic"/>
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>