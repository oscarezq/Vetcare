<Window x:Class="Vetcare.Presentacion.HistorialesClinicos.WindowConsulta"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de Consulta"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F6">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock x:Name="lblTitulo" Text="REGISTRAR CONSULTA" 
                       FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
            <Rectangle Height="4" Fill="#27AE60" HorizontalAlignment="Left" Width="40" RadiusX="2" RadiusY="2" Margin="0,8,0,0"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,30">
            <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,10,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="MASCOTA" FontSize="10" FontWeight="Black" Foreground="#95A5A6" Margin="0,0,0,5"/>
                    <TextBlock x:Name="txtMascotaDisplay" FontSize="16" Foreground="#2C3E50" FontWeight="SemiBold" Text="Nombre Mascota"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="15" Margin="5,0,5,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="VETERINARIO" FontSize="10" FontWeight="Black" Foreground="#95A5A6" Margin="0,0,0,5"/>
                    <TextBlock x:Name="txtVeterinarioDisplay" FontSize="16" Foreground="#2C3E50" FontWeight="SemiBold" Text="Nombre Vet"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="15" Margin="10,0,0,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="FECHA DE CITA" FontSize="10" FontWeight="Black" Foreground="#95A5A6" Margin="0,0,0,5"/>
                    <TextBlock x:Name="txtFechaDisplay" FontSize="16" Foreground="#2C3E50" FontWeight="SemiBold" Text="01/01/2024"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="25" BorderBrush="#D5DBDB" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,25" VerticalAlignment="Bottom">
                        <StackPanel Width="150">
                            <TextBlock Text="Peso (kg)" FontSize="12" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,8"/>
                            <TextBox x:Name="txtPeso" Height="35" VerticalContentAlignment="Center" Padding="10,0" 
                             BorderBrush="#BDC3C7" BorderThickness="1"/>
                        </StackPanel>

                        <CheckBox x:Name="chkNoPesado" 
                          Content="No se ha podido pesar" 
                          Margin="20,0,0,8" 
                          VerticalAlignment="Bottom"
                          FontSize="12" Foreground="#7F8C8D"
                          Checked="chkNoPesado_Checked" 
                          Unchecked="chkNoPesado_Unchecked"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Diagnóstico Clínico" FontSize="12" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtDiagnostico" 
                         MinHeight="60" MaxHeight="200" 
                         AcceptsReturn="True" TextWrapping="Wrap" 
                         VerticalContentAlignment="Top"
                         Padding="10" BorderBrush="#BDC3C7" Margin="0,0,0,20"/>

                        <TextBlock Text="Tratamiento" FontSize="12" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtTratamiento" 
                         MinHeight="60" MaxHeight="200" 
                         AcceptsReturn="True" TextWrapping="Wrap" 
                         VerticalContentAlignment="Top"
                         Padding="10" BorderBrush="#BDC3C7" Margin="0,0,0,20"/>

                        <TextBlock Text="Observaciones Adicionales" FontSize="12" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtObservaciones" 
                         MinHeight="50" MaxHeight="150" 
                         AcceptsReturn="True" TextWrapping="Wrap" 
                         VerticalContentAlignment="Top"
                         Padding="10" BorderBrush="#BDC3C7"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button x:Name="btnCancelar" Content="Cancelar" Width="110" Height="40" Background="Transparent" 
                    BorderBrush="#BDC3C7" BorderThickness="1" Foreground="#7F8C8D" Margin="0,0,15,0"
                    Cursor="Hand" Click="btnCancelar_Click"/>

            <Button x:Name="btnGuardar" Content="GUARDAR CONSULTA" Width="200" Height="40" IsDefault="True"
                    Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0"
                    Cursor="Hand" Click="btnGuardar_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="20"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>