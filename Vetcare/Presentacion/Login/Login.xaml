<Window x:Class="Vetcare.Presentacion.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acceso al Sistema" Height="550" Width="500" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F0F2F5"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True" Icon="/Resources/icono.ico">

    <Grid>
        <Border Background="White" VerticalAlignment="Center" HorizontalAlignment="Center" 
                Padding="30" CornerRadius="10" Width="320">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="0" RenderingBias="Quality" ShadowDepth="1" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>
                <Image Height="100" Source="/Resources/icono.png"/>

                <TextBlock Text="¡BIENVENIDO!" FontSize="26" FontWeight="Bold" 
                           HorizontalAlignment="Center" Foreground="#2C3E50" Margin="0,20,0,30"/>

                <TextBlock Text="Usuario" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsuario" Height="35" VerticalContentAlignment="Center" 
                         Padding="5,0" Margin="0,0,0,15"/>

                <TextBlock Text="Contraseña" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="35" VerticalContentAlignment="Center" 
                             Padding="5,0" Margin="0,0,0,25"/>

                <Button x:Name="btnEntrar" Content="INICIAR SESIÓN" Height="40" 
                        Background="#27AE60" Foreground="White" FontWeight="Bold" 
                        Cursor="Hand" Click="BtnEntrar_Click" IsDefault="True">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>