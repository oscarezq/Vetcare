<Page x:Class="Vetcare.Presentacion.Facturas.PageFacturas"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1100"
      Title="Gestión de Facturas">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderBrush="#D5DBDB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="BUSCAR POR CAMPO" FontSize="11" FontWeight="Bold" Foreground="#E67E22" Margin="5,0,0,10"/>

                <!-- Cambia Columns de 4 a 5 para que quepa el nuevo campo -->
                <UniformGrid Columns="4" Margin="0,0,0,15">
                    <UniformGrid.Resources>
                        <Style TargetType="TextBox">
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="5,0"/>
                        </Style>
                    </UniformGrid.Resources>

                    <!-- CAMPO 1: Cliente -->
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Cliente" FontSize="10" Foreground="#7F8C8D"/>
                        <TextBox x:Name="txtBuscaCliente" TextChanged="FiltroFactura_Changed"/>
                    </StackPanel>

                    <!-- CAMPO 2: Nº Factura -->
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Nº Factura" FontSize="10" Foreground="#7F8C8D"/>
                        <TextBox x:Name="txtBuscaNumero" TextChanged="FiltroFactura_Changed"/>
                    </StackPanel>

                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Fecha - Desde" FontSize="10" Foreground="#7F8C8D"/>
                        <DatePicker x:Name="dpDesde" Height="28" VerticalContentAlignment="Center" SelectedDateChanged="FiltroFactura_Changed"/>
                    </StackPanel>

                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Fecha - Hasta" FontSize="10" Foreground="#7F8C8D"/>
                        <DatePicker x:Name="dpHasta" Height="28" VerticalContentAlignment="Center" SelectedDateChanged="FiltroFactura_Changed"/>
                    </StackPanel>

                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Estado" FontSize="10" Foreground="#7F8C8D"/>
                        <ComboBox x:Name="cbEstado" Height="28" VerticalContentAlignment="Center" SelectionChanged="FiltroFactura_Changed">
                            <ComboBoxItem Content="Todos" IsSelected="True"/>
                            <ComboBoxItem Content="Pagada"/>
                            <ComboBoxItem Content="Pendiente"/>
                            <ComboBoxItem Content="Anulada"/>
                        </ComboBox>
                    </StackPanel>
                </UniformGrid>

                <Separator Background="#EBEDEF" Margin="5,5,5,15"/>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ORDENAR POR:" FontSize="11" FontWeight="Bold" Foreground="#2E86C1" VerticalAlignment="Center" Margin="5,0,15,0"/>

                    <ComboBox x:Name="cbOrdenarPor" Width="150" Height="28" VerticalContentAlignment="Center" SelectionChanged="FiltroFactura_Changed">
                        <ComboBoxItem Content="Fecha" IsSelected="True"/>
                        <ComboBoxItem Content="Cliente"/>
                        <ComboBoxItem Content="Total"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                        <RadioButton x:Name="rbDesc" Content="Más recientes" IsChecked="True" Margin="0,0,15,0" Checked="FiltroFactura_Changed"/>
                        <RadioButton x:Name="rbAsc" Content="Más antiguas" Checked="FiltroFactura_Changed"/>
                    </StackPanel>

                    <Button Content="Limpiar Filtros" Margin="30,0,0,0" Padding="15,0" Click="BtnLimpiar_Click" Height="28" Cursor="Hand" Background="#F4F6F7" BorderBrush="#D5DBDB"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" BorderBrush="#D5DBDB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,15">
                    <TextBlock Text="Historial de Facturación" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>

                    <Button DockPanel.Dock="Right" x:Name="btnNuevaFactura" Content="+ Generar Factura" Click="BtnNuevaFactura_Click"
                            Background="#2E86C1" Foreground="White" FontWeight="Bold" Padding="20,0" Height="38" Cursor="Hand" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </DockPanel>

                <DataGrid x:Name="dgFacturas"
          Grid.Row="1"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True"
          MouseDoubleClick="DgFacturas_MouseDoubleClick"
          GridLinesVisibility="None"
          BorderThickness="0"
          HeadersVisibility="Column"
          CanUserSortColumns="False"
          CanUserReorderColumns="False"
          Background="White"
          FontSize="14"
          RowHeight="50"
          ColumnHeaderHeight="40"
          SelectionMode="Single"
          SelectionUnit="FullRow"
          HorizontalScrollBarVisibility="Auto" CanUserResizeColumns="False">

                    <DataGrid.Resources>
                        <!-- Selección limpia -->
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="Black"/>

                        <!-- CELDAS -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="Transparent" BorderThickness="0" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <!-- HEADERS -->
                        <Style x:Key="HeaderStyleComun" TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9F9"/>
                            <Setter Property="Foreground" Value="#566573"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E67E22"/>
                        </Style>

                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyleComun}"/>
                    </DataGrid.Resources>

                    <!-- FILAS -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="#EBEDEF"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F4F6F7"/>
                                </Trigger>

                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF5FB"/>
                                    <Setter Property="Foreground" Value="#2E86C1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- COLUMNAS -->
                    <DataGrid.Columns>

                        <!-- ESTADO -->
                        <DataGridTemplateColumn Header="ESTADO" Width="120">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyleComun}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="brdEstado" CornerRadius="10" Padding="8,3" HorizontalAlignment="Center">
                                        <TextBlock x:Name="txtEstado" Text="{Binding Estado}" FontSize="11" FontWeight="Bold"/>
                                    </Border>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Estado}" Value="Pagada">
                                            <Setter TargetName="brdEstado" Property="Background" Value="#EAFAF1"/>
                                            <Setter TargetName="txtEstado" Property="Foreground" Value="#27AE60"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                            <Setter TargetName="brdEstado" Property="Background" Value="#FEF9E7"/>
                                            <Setter TargetName="txtEstado" Property="Foreground" Value="#F1C40F"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding Estado}" Value="Anulada">
                                            <Setter TargetName="brdEstado" Property="Background" Value="#FDEDEC"/>
                                            <Setter TargetName="txtEstado" Property="Foreground" Value="#E74C3C"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Nº FACTURA -->
                        <DataGridTextColumn Header="Nº FACTURA"
                            Binding="{Binding NumeroFactura}"
                            Width="*"
                            Foreground="#2E86C1"
                            FontWeight="SemiBold"/>

                        <!-- FECHA -->
                        <DataGridTextColumn Header="FECHA"
                            Binding="{Binding FechaEmision, StringFormat=\{0:dd/MM/yyyy\}}"
                            Width="*"/>

                        <!-- CLIENTE -->
                        <DataGridTemplateColumn Header="CLIENTE" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NombreApellidosCliente}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- TOTAL -->
                        <DataGridTextColumn Header="TOTAL"
                            Binding="{Binding Total, StringFormat={}{0:N2} €}"
                            Width="130"
                            Foreground="#27AE60"
                            FontWeight="Bold"/>

                        <!-- ACCIONES -->
                        <!-- ACCIONES -->
                        <DataGridTemplateColumn Header="ACCIONES" Width="180">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyleComun}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                        <!-- VER DETALLE -->
                                        <Button Content="👁"
                                                ToolTip="Ver Detalle"
                                                Click="BtnVerDetalle_Click"
                                                Margin="2,0"
                                                Background="#EBF5FB"
                                                Foreground="#2E86C1"
                                                Width="35"
                                                Height="30"
                                                BorderBrush="#AED6F1"
                                                Cursor="Hand"/>

                                        <!-- IMPRIMIR -->
                                        <Button Content="🖨"
                                                ToolTip="Imprimir Factura"
                                                Click="BtnImprimir_Click"
                                                Margin="2,0"
                                                Background="#E8F8F5"
                                                Foreground="#17A589"
                                                Width="35"
                                                Height="30"
                                                BorderBrush="#A3E4D7"
                                                Cursor="Hand"/>

                                        <!-- ANULAR: solo visible si está pendiente -->
                                        <Button Content="❌"
                                                ToolTip="Anular Factura"
                                                Click="BtnAnular_Click"
                                                Margin="2,0"
                                                Background="#FDEDEC"
                                                Foreground="#CB4335"
                                                Width="35"
                                                Height="30"
                                                BorderBrush="#FADBD8"
                                                Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>