<Window x:Class="Vetcare.Presentacion.Facturas.WindowFactura"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva Factura - Vetcare" Height="850" Width="950" 
        WindowStartupLocation="CenterScreen" Background="#F4F6F7">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="GENERAR NUEVA FACTURA" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
            <Rectangle Height="3" Fill="#E67E22" HorizontalAlignment="Left" Width="50" Margin="2,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#D5DBDB" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="CLIENTE / DUEÑO" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <Button x:Name="btnSeleccionarCliente" Click="btnSeleccionarCliente_Click" Height="32" Background="White" BorderBrush="#D5DBDB" HorizontalContentAlignment="Stretch">
                        <Grid Margin="5,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtNombreCliente" Text="Seleccionar cliente..." VerticalAlignment="Center" Foreground="#7F8C8D"/>
                            <TextBlock Grid.Column="1" Text="👤" VerticalAlignment="Center" Foreground="#E67E22" Margin="5,0"/>
                        </Grid>
                    </Button>
                    <TextBox x:Name="txtIdCliente" Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="MÉTODO DE PAGO" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cbMetodoPago" Height="32" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Efectivo" IsSelected="True"/>
                        <ComboBoxItem Content="Tarjeta"/>
                        <ComboBoxItem Content="Transferencia"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Nº FACTURA" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNumFactura" Height="32" IsReadOnly="True" Background="#F8F9F9" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" BorderBrush="#D5DBDB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="CONCEPTO" FontSize="10" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,3"/>
                        <Button x:Name="btnSeleccionarServicio" Click="btnSeleccionarServicio_Click" Height="32" Background="White" BorderBrush="#D5DBDB" HorizontalContentAlignment="Stretch">
                            <Grid Margin="5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="txtNombreServicio" Text="Presione para buscar un servicio o producto..." VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                <TextBlock Grid.Column="1" Text="🔍" VerticalAlignment="Center" Foreground="#E67E22"/>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="CANT." FontSize="10" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="-" Click="btnCantidadMenos_Click" Width="30" Height="32" Background="#F2F3F4" BorderBrush="#D5DBDB" FontWeight="Bold"/>
                            <TextBox x:Name="txtCantidad" Width="45" Height="32" Text="1" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderBrush="#D5DBDB" IsReadOnly="True" FontWeight="Bold"/>
                            <Button Content="+" Click="btnCantidadMas_Click" Width="30" Height="32" Background="#F2F3F4" BorderBrush="#D5DBDB" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="btnAgregar" Grid.Column="2" Content="AÑADIR LÍNEA" Click="btnAgregar_Click" VerticalAlignment="Bottom" Background="#27AE60" Foreground="White" Width="130" Height="32" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <DataGrid x:Name="dgDetalles" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" 
          RowHeight="60" HeadersVisibility="Column" GridLinesVisibility="None" 
          HorizontalGridLinesBrush="#EBEDEF" BorderThickness="0" Background="White" 
          SelectionMode="Single" RowHeaderWidth="0" FontSize="15">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FDFDFD"/>
                            <Setter Property="Foreground" Value="#85929E"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Height" Value="45"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E67E22"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="#2C3E50"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF5FB"/>
                                    <Setter Property="Foreground" Value="#2E86C1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                                        <Border Padding="{TemplateBinding Padding}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                SnapsToDevicePixels="True">
                                            <ContentPresenter VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Foreground}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="TIPO" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="brdTipo" CornerRadius="4" Padding="8,4" HorizontalAlignment="Center" Background="#F2F4F4">
                                        <TextBlock x:Name="txtTipoLabel" Text="Servicio" FontSize="11" FontWeight="Bold" Foreground="#9B59B6"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Tipo}" Value="Producto">
                                            <Setter TargetName="txtTipoLabel" Property="Text" Value="PRODUCTO"/>
                                            <Setter TargetName="txtTipoLabel" Property="Foreground" Value="#3498DB"/>
                                            <Setter TargetName="brdTipo" Property="Background" Value="#EAF2F8"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tipo}" Value="Servicio">
                                            <Setter TargetName="txtTipoLabel" Property="Text" Value="SERVICIO"/>
                                            <Setter TargetName="txtTipoLabel" Property="Foreground" Value="#9B59B6"/>
                                            <Setter TargetName="brdTipo" Property="Background" Value="#F5EEF8"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="CONCEPTO" Binding="{Binding NombreConcepto}" Width="*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="15,0"/>
                                    <Setter Property="FontSize" Value="14"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="CANTIDAD" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="-" Click="btnDisminuir_Click" Width="32" Height="32" Background="#F2F3F4" BorderBrush="#D5DBDB" FontSize="16"/>
                                        <Border BorderBrush="#D5DBDB" BorderThickness="0,1" Width="45" Height="32">
                                            <TextBlock Text="{Binding Cantidad}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                                        </Border>
                                        <Button Content="+" Click="btnAumentar_Click" Width="32" Height="32" Background="#F2F3F4" BorderBrush="#D5DBDB" FontSize="16"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="IVA %" Binding="{Binding IvaPorcentaje, StringFormat={}{0}%}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="15"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="PRECIO U." Binding="{Binding PrecioUnitario, StringFormat={}{0:N2}€}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="15"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="SUBTOTAL" Binding="{Binding Subtotal, StringFormat={}{0:N2}€}" Width="130" FontWeight="Bold">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#2E86C1"/>
                                    <Setter Property="Margin" Value="0,0,20,0"/>
                                    <Setter Property="FontSize" Value="17"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑" Click="btnQuitar_Click" Background="Transparent" BorderThickness="0" 
                            Foreground="#E74C3C" FontSize="20" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="OBSERVACIONES" FontSize="11" FontWeight="SemiBold" Foreground="#566573"/>
                <TextBox x:Name="txtObservaciones" Height="100" Margin="0,5,20,0" TextWrapping="Wrap" AcceptsReturn="True" BorderBrush="#D5DBDB" Padding="5"/>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#D5DBDB" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="Base Imponible:" Foreground="#566573" FontSize="13"/>
                            <TextBlock x:Name="lblBaseImponible" Text="0,00 €" HorizontalAlignment="Right" Foreground="#2C3E50" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="IVA:" Foreground="#566573" FontSize="13"/>
                            </StackPanel>
                            <TextBlock x:Name="lblIvaTotal" Text="0,00 €" HorizontalAlignment="Right" Foreground="#2C3E50" FontWeight="SemiBold"/>
                        </Grid>
                        <Separator Background="#EBEDEF" Margin="0,5"/>
                        <Grid Margin="0,5,0,0">
                            <TextBlock Text="TOTAL FACTURA:" Foreground="#2C3E50" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblTotal" Text="0,00 €" Foreground="#E67E22" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="CANCELAR" Click="btnCancelar_Click" Height="40" Background="#BDC3C7" Foreground="Black" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Grid.Column="2" x:Name="btnGuardar" Content="GUARDAR FACTURA" Click="btnGuardar_Click" Height="40" Background="#2E86C1" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>