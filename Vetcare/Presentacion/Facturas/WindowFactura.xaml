<Window x:Class="Vetcare.Presentacion.Facturas.WindowFactura"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva Factura - Vetcare" Height="700" Width="950" 
        WindowStartupLocation="CenterScreen" Background="#F4F6F7">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="GENERAR NUEVA FACTURA" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
            <Rectangle Height="3" Fill="#E67E22" HorizontalAlignment="Left" Width="50" Margin="2,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#D5DBDB" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="CLIENTE / DUEÑO" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <Button x:Name="btnSeleccionarCliente" Click="btnSeleccionarCliente_Click" Height="32" Background="White" BorderBrush="#D5DBDB" HorizontalContentAlignment="Stretch">
                        <Grid Margin="5,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtNombreCliente" Text="Seleccionar cliente..." VerticalAlignment="Center" Foreground="#7F8C8D"/>
                            <TextBlock Grid.Column="1" Text="👤" VerticalAlignment="Center" Foreground="#E67E22" Margin="5,0"/>
                        </Grid>
                    </Button>
                    <TextBox x:Name="txtIdCliente" Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="MÉTODO DE PAGO" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cbMetodoPago" Height="32" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Efectivo" IsSelected="True"/>
                        <ComboBoxItem Content="Tarjeta"/>
                        <ComboBoxItem Content="Transferencia"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Nº FACTURA" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNumFactura" Height="32" IsReadOnly="True" Background="#F8F9F9" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" BorderBrush="#D5DBDB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="SERVICIO" FontSize="10" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,3"/>
                        <Button x:Name="btnSeleccionarServicio" Click="btnSeleccionarServicio_Click" Width="300" Height="32" Background="White" BorderBrush="#D5DBDB" HorizontalContentAlignment="Stretch">
                            <Grid Margin="5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="txtNombreServicio" Text="Seleccionar servicio..." VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                <TextBlock Grid.Column="1" Text="🔍" VerticalAlignment="Center" Foreground="#E67E22" Margin="5,0"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="CANT." FontSize="10" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,3"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="-" Click="btnCantidadMenos_Click"
                                    Width="30" Height="32"
                                    Background="#F2F3F4"
                                    BorderBrush="#D5DBDB"
                                    FontWeight="Bold"/>

                            <TextBox x:Name="txtCantidad"
                                     Width="40"
                                     Height="32"
                                     Text="1"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#D5DBDB"/>

                            <Button Content="+" Click="btnCantidadMas_Click"
                                    Width="30" Height="32"
                                    Background="#F2F3F4"
                                    BorderBrush="#D5DBDB"
                                    FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                    <Button x:Name="btnAgregar" Content="AÑADIR" Click="btnAgregar_Click" VerticalAlignment="Bottom" Background="#27AE60" Foreground="White" Width="100" Height="32" BorderThickness="0" FontWeight="Bold"/>
                </StackPanel>

                <DataGrid x:Name="dgDetalles" Grid.Row="1" AutoGenerateColumns="False" 
          CanUserAddRows="False" RowHeight="50"
          HeadersVisibility="Column" 
          GridLinesVisibility="None" 
          HorizontalGridLinesBrush="#EBEDEF" 
          BorderThickness="0" Background="White" 
          SelectionMode="Single" SelectionUnit="FullRow"
          Focusable="False"
          RowHeaderWidth="0">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="#EBEDEF"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#F4F6F7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="Foreground" Value="#2C3E50"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        </Style>

                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FDFDFD"/>
                            <Setter Property="Foreground" Value="#85929E"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="Height" Value="40"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E67E22"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="SERVICIO" Binding="{Binding NombreServicio}" Width="*" IsReadOnly="True"/>

                        <DataGridTemplateColumn Header="CANTIDAD" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="-" Click="btnDisminuir_Click" Width="30" Height="30" Background="#F2F3F4" BorderBrush="#D5DBDB" Foreground="#2C3E50" FontWeight="Bold">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4,0,0,4"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                        <Border BorderBrush="#D5DBDB" BorderThickness="0,1" Background="White" Width="40" Height="30">
                                            <TextBlock Text="{Binding Cantidad}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#2C3E50"/>
                                        </Border>
                                        <Button Content="+" Click="btnAumentar_Click" Width="30" Height="30" Background="#F2F3F4" BorderBrush="#D5DBDB" Foreground="#2C3E50" FontWeight="Bold">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="0,4,4,0"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="PRECIO U." Binding="{Binding PrecioUnitario, StringFormat={}{0:N2}€}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="SUBTOTAL" Binding="{Binding Subtotal, StringFormat={}{0:N2}€}" Width="120" FontWeight="Bold" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#2E86C1"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑" Click="btnQuitar_Click" Background="Transparent" BorderThickness="0" Foreground="#E74C3C" FontSize="18" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="OBSERVACIONES" FontSize="11" FontWeight="SemiBold" Foreground="#566573"/>
                <TextBox x:Name="txtObservaciones" Height="60" Margin="0,5,20,0" TextWrapping="Wrap" AcceptsReturn="True" BorderBrush="#D5DBDB"/>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                <Border Background="#2C3E50" CornerRadius="5" Padding="20,10" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="TOTAL:" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblTotal" Text="0,00 €" Foreground="#F1C40F" FontSize="22" FontWeight="Bold" Margin="15,0,0,0"/>
                    </StackPanel>
                </Border>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="CANCELAR" Click="btnCancelar_Click" Width="100" Height="35" Margin="0,0,10,0" Background="#BDC3C7" BorderThickness="0"/>
                    <Button x:Name="btnGuardar" Content="GUARDAR" Click="btnGuardar_Click" Width="120" Height="35" Background="#2E86C1" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>