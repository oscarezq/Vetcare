<Window x:Class="Vetcare.Presentacion.Facturas.WindowDetalleFactura"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de Factura" Height="750" Width="950"
        WindowStartupLocation="CenterScreen" Background="#F4F6F7">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <DockPanel>
                <TextBlock x:Name="lblNumFactura" Text="FACTURA: #0000" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                <Border x:Name="brdEstado" CornerRadius="12" Padding="15,5" HorizontalAlignment="Right" Background="#27AE60" VerticalAlignment="Center">
                    <TextBlock x:Name="txtEstado" Text="PAGADA" Foreground="White" FontSize="13" FontWeight="Bold"/>
                </Border>
            </DockPanel>
            <Rectangle Height="4" Fill="#E67E22" HorizontalAlignment="Left" Width="60" Margin="2,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15" BorderBrush="#D5DBDB" BorderThickness="1">
            <UniformGrid Columns="3">
                <StackPanel>
                    <TextBlock Text="CLIENTE" FontSize="11" FontWeight="Bold" Foreground="#85929E"/>
                    <TextBlock x:Name="txtCliente" Text="Nombre del Cliente" FontSize="16" Foreground="#2C3E50" Margin="0,5,0,0" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="FECHA DE EMISIÓN" FontSize="11" FontWeight="Bold" Foreground="#85929E"/>
                    <TextBlock x:Name="txtFecha" Text="01/01/2026" FontSize="16" Foreground="#2C3E50" Margin="0,5,0,0" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="MÉTODO DE PAGO" FontSize="11" FontWeight="Bold" Foreground="#85929E"/>
                    <TextBlock x:Name="txtMetodoPago" Text="Efectivo" FontSize="16" Foreground="#2C3E50" Margin="0,5,0,0" FontWeight="SemiBold"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="8" BorderBrush="#D5DBDB" BorderThickness="1" Padding="10">
            <DataGrid x:Name="dgDetalles" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" CanUserSortColumns="False"
                      HorizontalGridLinesBrush="#F2F4F4" Background="White" BorderThickness="0" 
                      RowHeight="60" FontSize="16" CanUserResizeColumns="False" CanUserReorderColumns="False">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8F9F9"/>
                        <Setter Property="Foreground" Value="#566573"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Height" Value="45"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="#E67E22"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="10,0"/>
                    </Style>

                    <Style x:Key="ColumnTextStyle" TargetType="TextBlock">
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Foreground" Value="#2C3E50"/>
                        <Setter Property="Margin" Value="10,0"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="CONCEPTO / SERVICIO" Binding="{Binding NombreConcepto}" Width="*" 
                                        ElementStyle="{StaticResource ColumnTextStyle}"/>

                    <DataGridTextColumn Header="CANTIDAD" Binding="{Binding Cantidad}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ColumnTextStyle}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="IVA (%)" Binding="{Binding IvaPorcentaje, StringFormat={}{0}%}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ColumnTextStyle}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="PRECIO U." Binding="{Binding PrecioUnitario, StringFormat={}{0:N2}€}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ColumnTextStyle}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="SUBTOTAL" Binding="{Binding TotalLinea, StringFormat={}{0:N2}€}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ColumnTextStyle}">
                                <Setter Property="Foreground" Value="#2E86C1"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,20,0"/>
                                <Setter Property="FontSize" Value="18"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="OBSERVACIONES" FontSize="11" FontWeight="SemiBold" Foreground="#566573"/>
                <TextBlock x:Name="txtObservaciones" Text="Sin observaciones." Margin="0,5,20,0" TextWrapping="Wrap" Foreground="#566573" FontSize="14" FontStyle="Italic"/>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#D5DBDB" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Base Imponible:" Foreground="#566573" FontSize="14"/>
                            <TextBlock x:Name="lblBaseImponible" Text="0,00 €" HorizontalAlignment="Right" Foreground="#2C3E50" FontWeight="Bold" FontSize="15"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="IVA:" Foreground="#566573" FontSize="14"/>
                            <TextBlock x:Name="lblIva" Text="0,00 €" HorizontalAlignment="Right" Foreground="#2C3E50" FontWeight="Bold" FontSize="15"/>
                        </Grid>
                        <Separator Background="#EBEDEF" Margin="0,5"/>
                        <Grid Margin="0,10,0,0">
                            <TextBlock Text="TOTAL FACTURA:" Foreground="#2C3E50" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblTotal" Text="0,00 €" Foreground="#E67E22" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button x:Name="btnMarcarPagada"
        Click="btnMarcarPagada_Click"
        Cursor="Hand"
        BorderThickness="0"
        Padding="14,6"
        FontWeight="SemiBold"
        FontSize="13"
        HorizontalAlignment="Right">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E8F8F5"/>
                            <Setter Property="Foreground" Value="#16A085"/>
                            <Setter Property="Content" Value="✔ Marcar como pagada"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Estado}" Value="Pagada">
                                    <Setter Property="Background" Value="#EAFAF1"/>
                                    <Setter Property="Foreground" Value="#27AE60"/>
                                    <Setter Property="Content" Value="✔ Factura pagada"/>
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                    CornerRadius="20">
                                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>