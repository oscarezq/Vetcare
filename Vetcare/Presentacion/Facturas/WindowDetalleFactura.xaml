<Window x:Class="Vetcare.Presentacion.Facturas.WindowDetalleFactura"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de Factura" Height="700" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F4F6F7">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <DockPanel>
                <TextBlock x:Name="lblNumFactura" Text="FACTURA: #0000" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
                <Border x:Name="brdEstado" CornerRadius="12" Padding="12,3" HorizontalAlignment="Right" Background="#27AE60" VerticalAlignment="Center">
                    <TextBlock x:Name="txtEstado" Text="PAGADA" Foreground="White" FontSize="12" FontWeight="Bold"/>
                </Border>
            </DockPanel>
            <Rectangle Height="3" Fill="#E67E22" HorizontalAlignment="Left" Width="50" Margin="2,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#D5DBDB" BorderThickness="1">
            <UniformGrid Columns="3">
                <StackPanel>
                    <TextBlock Text="CLIENTE" FontSize="10" FontWeight="Bold" Foreground="#85929E"/>
                    <TextBlock x:Name="txtCliente" Text="Nombre del Cliente" FontSize="14" Foreground="#2C3E50" Margin="0,5,0,0" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="FECHA DE EMISIÓN" FontSize="10" FontWeight="Bold" Foreground="#85929E"/>
                    <TextBlock x:Name="txtFecha" Text="01/01/2026" FontSize="14" Foreground="#2C3E50" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="MÉTODO DE PAGO" FontSize="10" FontWeight="Bold" Foreground="#85929E"/>
                    <TextBlock x:Name="txtMetodoPago" Text="Efectivo" FontSize="14" Foreground="#2C3E50" Margin="0,5,0,0"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="8" BorderBrush="#D5DBDB" BorderThickness="1" Padding="10">
            <DataGrid x:Name="dgDetalles" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="None" Background="White" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="CONCEPTO / SERVICIO" Binding="{Binding NombreConcepto}" Width="*"/>
                    <DataGridTextColumn Header="CANTIDAD" Binding="{Binding Cantidad}" Width="100"/>
                    <DataGridTextColumn Header="PRECIO U." Binding="{Binding PrecioUnitario, StringFormat={}{0:N2}€}" Width="120"/>
                    <DataGridTextColumn Header="IVA (%)" Binding="{Binding IvaPorcentaje, StringFormat={}{0}%}" Width="80"/>
                    <DataGridTextColumn Header="SUBTOTAL" Binding="{Binding Subtotal, StringFormat={}{0:N2}€}" Width="120" FontWeight="Bold">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#2E86C1"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,15,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="OBSERVACIONES" FontSize="11" FontWeight="SemiBold" Foreground="#566573"/>
                <TextBlock x:Name="txtObservaciones" Text="Sin observaciones." Margin="0,5,20,0" TextWrapping="Wrap" Foreground="#566573" FontSize="13" FontStyle="Italic"/>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#D5DBDB" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="Base Imponible:" Foreground="#566573" FontSize="13"/>
                            <TextBlock x:Name="lblBaseImponible" Text="0,00 €" HorizontalAlignment="Right" Foreground="#2C3E50" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="IVA:" Foreground="#566573" FontSize="13"/>
                            <TextBlock x:Name="lblIva" Text="0,00 €" HorizontalAlignment="Right" Foreground="#2C3E50" FontWeight="SemiBold"/>
                        </Grid>
                        <Separator Background="#EBEDEF" Margin="0,5"/>
                        <Grid Margin="0,5,0,0">
                            <TextBlock Text="TOTAL:" Foreground="#2C3E50" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblTotal" Text="0,00 €" Foreground="#E67E22" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="CERRAR" Click="btnCerrar_Click" Height="40" Background="#BDC3C7" Foreground="Black" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Grid.Column="2" x:Name="btnMarcarPagada" Content="MARCAR PAGADA" Click="btnMarcarPagada_Click" Height="40" Background="#2E86C1" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>