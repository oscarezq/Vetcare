<Window x:Class="Vetcare.Presentacion.Usuarios.WindowFichaUsuario"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ficha de Usuario" Height="560" Width="1000"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#ECF0F1">

    <Window.Resources>
        <!-- Estilos de menú y textos -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="20,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#34495E"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1ABC9C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="Gray"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,2,0,12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= MENU LATERAL ================= -->
        <Border Background="#2C3E50" Grid.Column="0">
            <StackPanel Margin="0,40,0,0">
                <TextBlock TextAlignment="Center" Margin="20,0,20,40" Foreground="White" FontSize="18" FontWeight="Bold" TextWrapping="Wrap">
                    <Run Text="{Binding Nombre}"/> <Run Text="{Binding Apellidos}"/>
                    <LineBreak/>
                    <Run Text="{Binding NombreRol}" FontSize="13" FontWeight="Normal" Foreground="#1ABC9C"/>
                </TextBlock>

                <Button x:Name="btnDatos"
                        Content="Datos Generales"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="btnDatos_Click"/>

                <Button x:Name="btnProfesional"
                        Content="Datos Profesionales"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="btnProfesional_Click"
                        Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- ================= PANEL PRINCIPAL ================= -->
        <Grid Grid.Column="1" Background="White" Margin="0">
            <!-- Datos Generales -->
            <Grid x:Name="panelDatosGenerales" Margin="50,40">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,30">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Perfil de Usuario" FontSize="26" FontWeight="Bold" Foreground="#2C3E50"/>
                        </StackPanel>

                        <Button x:Name="btnEditarUsuario" Content="Editar Información" 
                            Width="160" Height="40" Background="#3498DB" Foreground="White" 
                            FontWeight="Bold" HorizontalAlignment="Right" Click="btnEditarUsuario_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </DockPanel>

                    <Grid Grid.Row="1" Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Nombre de Usuario" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding Username}" Style="{StaticResource ValueStyle}"/>

                            <TextBlock Text="Nombre" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding Nombre}" Style="{StaticResource ValueStyle}"/>

                            <TextBlock Text="Apellidos" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding Apellidos}" Style="{StaticResource ValueStyle}"/>

                            <TextBlock Text="Correo Electrónico" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding Email}" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="20,0,0,0">
                            <TextBlock Text="Estado" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="Cuenta Activa" Foreground="#27AE60" Style="{StaticResource ValueStyle}"/>

                            <TextBlock Text="Fecha de alta" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding FechaAlta, StringFormat=dd/MM/yyyy}" Style="{StaticResource ValueStyle}"/>

                            <TextBlock Text="Teléfono" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding Telefono}" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Datos Profesionales -->
            <Grid x:Name="panelDatosProfesional" Margin="50,40" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Datos Profesionales"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,30"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Número de Colegiado -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Número de Colegiado" Style="{StaticResource LabelStyle}" />
                            <TextBlock x:Name="txtNumeroColegiado" Style="{StaticResource ValueStyle}" />
                        </StackPanel>

                        <!-- Especialidad -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Especialidad" Style="{StaticResource LabelStyle}" />
                            <TextBlock x:Name="txtEspecialidad" Style="{StaticResource ValueStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>