<Window x:Class="Vetcare.Presentacion.Usuarios.WindowFichaUsuario"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ficha de Usuario" Height="650" Width="850"
        WindowStartupLocation="CenterOwner" Background="#F8FAFC"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True" 
        SnapsToDevicePixels="True" FontFamily="Segoe UI">

    <!-- Recursos de estilos reutilizables -->
    <Window.Resources>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

    </Window.Resources>

    <!-- Contenedor principal -->
    <Grid Margin="40,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabecera con título y botón editar -->
        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,35">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Ficha de Usuario" FontSize="28" FontWeight="Bold" Foreground="#2C3E50"/>
            </StackPanel>

            <!-- Botón para editar usuario -->
            <Button DockPanel.Dock="Right" 
                    x:Name="btnEditarUsuario"
                    Content="Editar Información"
                    Click="BtnEditarUsuario_Click"
                    Background="#3498DB" Foreground="White" 
                    Width="180" Height="45" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DockPanel>

        <!-- Scroll para contenido -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Sección: Datos personales -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="DATOS PERSONALES" Style="{StaticResource SectionTitleStyle}"/>

                        <UniformGrid Columns="3">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="NOMBRE" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding Nombre}" Style="{StaticResource ValueStyle}"/>

                                <TextBlock Text="CORREO ELECTRÓNICO" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding Email}" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="APELLIDOS" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding Apellidos}" Style="{StaticResource ValueStyle}"/>

                                <TextBlock Text="TELÉFONO" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding Telefono}" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="ESTADO" Style="{StaticResource LabelStyle}"/>

                                <!-- Estado visual del usuario -->
                                <Border HorizontalAlignment="Left" CornerRadius="6" Padding="8,2" Margin="0,0,0,20">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <!-- estado por defecto (INACTIVO) -->
                                            <Setter Property="Background" Value="#FEE2E2"/>

                                            <Style.Triggers>

                                                <!-- ACTIVO -->
                                                <DataTrigger Binding="{Binding Activo}" Value="True">
                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                </DataTrigger>

                                                <!-- INACTIVO -->
                                                <DataTrigger Binding="{Binding Activo}" Value="False">
                                                    <Setter Property="Background" Value="#FAD2CA"/>
                                                </DataTrigger>

                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="Bold" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="INACTIVO"/>
                                                <Setter Property="Foreground" Value="#991B1B"/>

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Activo}" Value="True">
                                                        <Setter Property="Text" Value="ACTIVO"/>
                                                        <Setter Property="Foreground" Value="#166534"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <TextBlock Text="FECHA DE ALTA" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding FechaAlta, StringFormat=dd/MM/yyyy}" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Sección: Acceso y seguridad -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="ACCESO Y SEGURIDAD" Style="{StaticResource SectionTitleStyle}"/>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,40,0">
                                <TextBlock Text="NOMBRE DE USUARIO" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding Username}" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="ROL ASIGNADO" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding NombreRol}" Style="{StaticResource ValueStyle}" Foreground="#3498DB"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Sección: Información profesional (solo veterinarios normalmente) -->
                <Border x:Name="seccionProfesional" Style="{StaticResource CardStyle}" Visibility="Visible">
                    <StackPanel>
                        <TextBlock Text="INFORMACIÓN PROFESIONAL" Style="{StaticResource SectionTitleStyle}"/>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,40,0">
                                <TextBlock Text="NÚMERO DE COLEGIADO" Style="{StaticResource LabelStyle}"/>
                                <TextBlock x:Name="txtNumeroColegiado" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="ESPECIALIDAD" Style="{StaticResource LabelStyle}"/>
                                <TextBlock x:Name="txtEspecialidad" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>