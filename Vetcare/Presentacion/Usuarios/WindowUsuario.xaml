<Window x:Class="Vetcare.Presentacion.Usuarios.WindowUsuario"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ficha de Usuario" Height="560" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9F9" Icon="/Resources/icono.png">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,15,0">
            <StackPanel>
                <StackPanel Margin="0,0,0,25">
                    <TextBlock x:Name="lblTitulo" Text="NUEVO USUARIO" FontSize="20" FontWeight="Bold" Foreground="#1B2631"/>
                    <Rectangle Height="2" Fill="#E67E22" HorizontalAlignment="Left" Width="50" Margin="2,5,0,0"/>
                </StackPanel>

                <UniformGrid Columns="2" Margin="0,0,0,15">
                    <StackPanel Margin="5">
                        <TextBlock Text="Username" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtUsername" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="Rol de Usuario" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cbRol" Height="30" 
                                  DisplayMemberPath="NombreRol" 
                                  SelectedValuePath="IdRol"
                                  SelectionChanged="cbRol_SelectionChanged" />
                    </StackPanel>
                </UniformGrid>

                <UniformGrid Columns="2" Margin="0,0,0,15">
                    <StackPanel Margin="5">
                        <TextBlock Text="Nombre" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtNombre" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Apellidos" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtApellidos" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>
                </UniformGrid>

                <UniformGrid Columns="2" Margin="0,0,0,15">
                    <StackPanel Margin="5">
                        <TextBlock Text="Email" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtEmail" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Teléfono" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtTelefono" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>
                </UniformGrid>

                <Border x:Name="borderVeterinario" 
                        Visibility="Collapsed" 
                        Background="#FDF2E9" 
                        CornerRadius="8" 
                        Padding="10" 
                        Margin="5,0,5,15" 
                        BorderBrush="#E67E22" 
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="DATOS PROFESIONALES (VETERINARIO)" FontSize="10" FontWeight="Bold" Foreground="#E67E22" Margin="0,0,0,10"/>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="5">
                                <TextBlock Text="Especialidad" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtEspecialidad" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                            </StackPanel>
                            <StackPanel Margin="5">
                                <TextBlock Text="Nº Colegiado" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtColegiado" Height="30" VerticalContentAlignment="Center" Padding="5,0" MaxLength="9"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <StackPanel >
                    <StackPanel x:Name="panelPassword" Margin="5">
                        <TextBlock x:Name="lblPassword" Text="Contraseña inicial" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="txtPassword" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                        <Border Background="#EBF5FB" CornerRadius="4" Margin="0,8,0,0" Padding="10,8">
                            <TextBlock Text="El usuario deberá crear una contraseña nueva en su primer acceso." 
                                   FontSize="10.5" Foreground="#566573" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnCancelar" Content="Cancelar" Width="90" Height="32" Margin="10,0" Click="btnCancelar_Click" Cursor="Hand" Background="#FBFCFC" BorderBrush="#D5DBDB"/>
            <Button x:Name="btnGuardar" Content="Guardar Usuario" Width="130" Height="32" Background="#E67E22" Foreground="White" FontWeight="Bold" Click="btnGuardar_Click" Cursor="Hand" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>