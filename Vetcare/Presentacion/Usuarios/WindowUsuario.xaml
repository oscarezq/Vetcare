<Window x:Class="Vetcare.Presentacion.Usuarios.WindowUsuario"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ficha de Usuario" Height="650" Width="950"
        WindowStartupLocation="CenterScreen" Background="#F8FAFC"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True" 
        SnapsToDevicePixels="True" FontFamily="Segoe UI">

    <!-- Recursos: estilos reutilizables -->
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ModernInput" TargetType="Control">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <!-- Contenedor principal -->
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scroll para evitar problemas en pantallas pequeñas -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,15,0">
            <StackPanel>

                <!-- Título -->
                <StackPanel Margin="0,0,0,25">
                    <TextBlock x:Name="lblTitulo" Text="NUEVO USUARIO" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                    <!-- Línea decorativa -->
                    <Rectangle Height="3" Fill="#E67E22" HorizontalAlignment="Left" Width="40" Margin="2,5,0,0"/>
                </StackPanel>

                <!-- USERNAME + ROL -->
                <UniformGrid Columns="2" Margin="0,0,0,15">
                    <StackPanel Margin="5">
                        <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtUsername" Style="{StaticResource ModernInput}"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="ROL DE USUARIO" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="cbRol" 
                                  Style="{StaticResource ModernCombo}"
                                  DisplayMemberPath="NombreRol" 
                                  SelectedValuePath="IdRol"
                                  SelectionChanged="CbRol_SelectionChanged"/>
                    </StackPanel>
                </UniformGrid>

                <!-- NOMBRE + APELLIDOS -->
                <UniformGrid Columns="2" Margin="0,0,0,15">
                    <StackPanel Margin="5">
                        <TextBlock Text="NOMBRE" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtNombre" Style="{StaticResource ModernInput}"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="APELLIDOS" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtApellidos" Style="{StaticResource ModernInput}"/>
                    </StackPanel>
                </UniformGrid>

                <!-- EMAIL + TELÉFONO -->
                <UniformGrid Columns="2" Margin="0,0,0,15">
                    <StackPanel Margin="5">
                        <TextBlock Text="EMAIL" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtEmail" Style="{StaticResource ModernInput}"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="TELÉFONO" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtTelefono" Style="{StaticResource ModernInput}"/>
                    </StackPanel>
                </UniformGrid>

                <!-- BLOQUE SOLO PARA VETERINARIOS -->
                <Border x:Name="borderVeterinario" 
                        Visibility="Collapsed" 
                        Background="#FFF7ED" 
                        CornerRadius="12" 
                        Padding="15" 
                        Margin="5,10,5,20" 
                        BorderBrush="#FED7AA" 
                        BorderThickness="1">
                    <StackPanel>
                        <!-- Título de sección -->
                        <TextBlock Text="DATOS PROFESIONALES (VETERINARIO)" FontSize="10" FontWeight="Bold" Foreground="#EA580C" Margin="0,0,0,12"/>

                        <!-- Campos específicos -->
                        <UniformGrid Columns="2">
                            <StackPanel Margin="5">
                                <TextBlock Text="ESPECIALIDAD" Style="{StaticResource FieldLabel}" Foreground="#C2410C"/>
                                <TextBox x:Name="txtEspecialidad" Style="{StaticResource ModernInput}" BorderBrush="#FDBA74"/>
                            </StackPanel>
                            <StackPanel Margin="5">
                                <TextBlock Text="Nº COLEGIADO" Style="{StaticResource FieldLabel}" Foreground="#C2410C"/>
                                <TextBox x:Name="txtColegiado" Style="{StaticResource ModernInput}" MaxLength="9" BorderBrush="#FDBA74"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- CONTRASEÑA -->
                <StackPanel x:Name="panelPassword" Margin="5,0,5,15">
                    <TextBlock x:Name="lblPassword" Text="CONTRASEÑA INICIAL" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="txtPassword" Style="{StaticResource ModernInput}"/>

                    <!-- Aviso informativo -->
                    <Border Background="#F0F9FF" CornerRadius="8" Margin="0,12,0,0" Padding="12" BorderBrush="#BAE6FD" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ℹ️" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="El usuario deberá crear una contraseña nueva en su primer acceso." 
                                       FontSize="11" Foreground="#0369A1" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- BOTONES -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">

            <!-- Botón cancelar -->
            <Button x:Name="btnCancelar" Content="Cancelar" Width="100" Height="42" 
                    Click="BtnCancelar_Click" Cursor="Hand" Background="Transparent" 
                    Foreground="#64748B" FontWeight="SemiBold" BorderThickness="0"/>

            <!-- Botón guardar -->
            <Button x:Name="btnGuardar" Content="Guardar Usuario" Width="160" Height="42" 
                    Background="#E67E22" Foreground="White" FontWeight="Bold" IsDefault="True"
                    Click="BtnGuardar_Click" Cursor="Hand" BorderThickness="0" Margin="10,0,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>