<Page x:Class="Vetcare.Presentacion.Usuarios.PageUsuarios"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1100"
      Title="Gestión de Usuarios">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderBrush="#D5DBDB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="FILTROS DE USUARIO" FontSize="11" FontWeight="Bold" Foreground="#E67E22" Margin="5,0,0,10"/>

                <Grid>
                    <UniformGrid Columns="4">
                        <StackPanel Margin="5">
                            <TextBlock Text="Username" FontSize="10" Foreground="#7F8C8D"/>
                            <TextBox x:Name="txtBuscaUsername" Height="25" TextChanged="FiltroUsuario_Changed"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="Nombre / Apellidos" FontSize="10" Foreground="#7F8C8D"/>
                            <TextBox x:Name="txtBuscaNombre" Height="25" TextChanged="FiltroUsuario_Changed"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="Rol" FontSize="10" Foreground="#7F8C8D"/>
                            <ComboBox x:Name="cbBuscaRol" Height="25" SelectionChanged="FiltroUsuario_Changed">
                                <ComboBoxItem Content="Todos" IsSelected="True"/>
                                <ComboBoxItem Content="Administrador"/>
                                <ComboBoxItem Content="Veterinario"/>
                                <ComboBoxItem Content="Recepcionista"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="Estado" FontSize="10" Foreground="#7F8C8D"/>
                            <ComboBox x:Name="cbBuscaEstado" Height="25" SelectionChanged="FiltroUsuario_Changed">
                                <ComboBoxItem Content="Todos" IsSelected="True"/>
                                <ComboBoxItem Content="Activo"/>
                                <ComboBoxItem Content="Inactivo"/>
                            </ComboBox>
                        </StackPanel>
                    </UniformGrid>
                </Grid>

                <Separator Background="#EBEDEF" Margin="5,15,5,10"/>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ORDENAR POR:" FontSize="11" FontWeight="Bold" Foreground="#2E86C1" VerticalAlignment="Center" Margin="5,0,15,0"/>
                    <ComboBox x:Name="cbOrdenarPor" Width="120" Height="25" SelectionChanged="FiltroUsuario_Changed">
                        <ComboBoxItem Content="Username" IsSelected="True"/>
                        <ComboBoxItem Content="Nombre"/>
                        <ComboBoxItem Content="Rol"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                        <RadioButton x:Name="rbAsc" Content="Ascendente" IsChecked="True" Margin="0,0,15,0" Checked="FiltroUsuario_Changed"/>
                        <RadioButton x:Name="rbDesc" Content="Descendente" Checked="FiltroUsuario_Changed"/>
                    </StackPanel>

                    <Button Content="Limpiar Filtros" Margin="30,0,0,0" Padding="15,0" Click="btnLimpiar_Click" Height="25" Cursor="Hand" Background="#F4F6F7" BorderBrush="#D5DBDB"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" BorderBrush="#D5DBDB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,15">
                    <TextBlock Text="Listado de Usuarios" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>

                    <Button DockPanel.Dock="Right" x:Name="btnNuevoUsuario" Content="+ Nuevo Usuario" Click="btnNuevoUsuario_Click"
                            Background="#27AE60" Foreground="White" FontWeight="Bold" Padding="20,0" Height="38" Cursor="Hand" BorderThickness="0" Margin="10,0,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </DockPanel>

                <DataGrid x:Name="dgUsuarios" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
          GridLinesVisibility="None" BorderThickness="0" HeadersVisibility="Column"
          Background="White" FontSize="14" RowHeight="50" ColumnHeaderHeight="40"
          SelectionMode="Extended" SelectionUnit="FullRow">

                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#2C3E50" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#2C3E50" />

                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="20,0,10,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="Transparent" BorderThickness="0" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style x:Key="LeftTextStyle" TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                        </Style>

                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9F9"/>
                            <Setter Property="Foreground" Value="#566573"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="20,0,10,0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E67E22"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="#EBEDEF"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F4F6F7"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF5FB"/>
                                    <Setter Property="Foreground" Value="#2E86C1"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="USERNAME" Binding="{Binding Username}" Width="250" ElementStyle="{StaticResource LeftTextStyle}"/>

                        <DataGridTemplateColumn Header="NOMBRE COMPLETO" Width="250">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Nombre}" Foreground="#2C3E50"/>
                                        <TextBlock Text=" "/>
                                        <TextBlock Text="{Binding Apellidos}" Foreground="#2C3E50"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="250" ElementStyle="{StaticResource LeftTextStyle}"/>

                        <DataGridTextColumn Header="TELÉFONO" Binding="{Binding Telefono}" Width="120" ElementStyle="{StaticResource LeftTextStyle}"/>

                        <DataGridTextColumn Header="ROL" Binding="{Binding NombreRol}" Width="*" ElementStyle="{StaticResource LeftTextStyle}"/>

                        <DataGridTemplateColumn Header="ESTADO" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="EstadoBorder" CornerRadius="10" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock x:Name="EstadoText" FontSize="11" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Activo}" Value="True">
                                            <Setter TargetName="EstadoBorder" Property="Background" Value="#27AE60"/>
                                            <Setter TargetName="EstadoText" Property="Text" Value="ACTIVO"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Activo}" Value="False">
                                            <Setter TargetName="EstadoBorder" Property="Background" Value="#95A5A6"/>
                                            <Setter TargetName="EstadoText" Property="Text" Value="INACTIVO"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="ACCIONES" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Button Content="✎" Click="btnEditarUsuario_Click" Margin="0,0,5,0" 
                                Background="#EBF5FB" Foreground="#2E86C1" Width="32" Height="28" BorderBrush="#AED6F1"/>
                                        <Button Content="🗑" Click="btnEliminarUsuario_Click" 
                                Background="#FDEDEC" Foreground="#CB4335" Width="32" Height="28" BorderBrush="#FADBD8"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>