<Window x:Class="Vetcare.Presentacion.Usuarios.WindowCambiarPassword"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Actualizar Contraseña" Height="400" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F8F9F9" Icon="/Resources/icono.png">

    <Border Padding="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,5">
                <TextBlock Text="SEGURIDAD" FontSize="12" FontWeight="Bold" Foreground="#E67E22"/>
                <TextBlock Text="Cambiar Contraseña" FontSize="22" FontWeight="Bold" Foreground="#1B2631"/>
                <TextBlock Text="Por seguridad, debes establecer una clave nueva para continuar." 
                           FontSize="11" Foreground="#566573" TextWrapping="Wrap" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Nueva Contraseña" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPassNueva" Height="35" VerticalContentAlignment="Center" Padding="8,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Confirmar Contraseña" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPassConfirmar" Height="35" VerticalContentAlignment="Center" Padding="8,0"/>
                </StackPanel>

                <TextBlock x:Name="lblError" Text="Las contraseñas no coinciden" Foreground="#CB4335" 
                           FontSize="11" HorizontalAlignment="Center" Visibility="Collapsed"/>
            </StackPanel>

            <Button Grid.Row="2" x:Name="btnActualizar" Content="Actualizar y Entrar" Height="40"
                    Background="#27AE60" Foreground="White" FontWeight="Bold" FontSize="14"
                    Click="btnActualizar_Click" Cursor="Hand" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Border>
</Window>