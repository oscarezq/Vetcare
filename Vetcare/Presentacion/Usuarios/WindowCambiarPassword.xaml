<Window x:Class="Vetcare.Presentacion.Usuarios.WindowCambiarPassword"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Actualizar Contraseña" Height="480" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F8F9F9" Icon="/Resources/icono.ico">

    <Border Padding="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock x:Name="txtTitulo" Text="Cambiar Contraseña" FontSize="22" FontWeight="Bold" Foreground="#1B2631"/>
                <Rectangle Height="3" Fill="#E67E22" HorizontalAlignment="Left" Width="40" Margin="2,5,0,8"/>
                <TextBlock x:Name="txtSubtitulo" Text="Por seguridad, debes establecer una clave nueva para continuar." 
                           FontSize="11" Foreground="#566573" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">

                <StackPanel x:Name="panelPassActual" Margin="0,0,0,15" Visibility="Collapsed">
                    <TextBlock Text="Contraseña Actual" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPassActual" Height="35" VerticalContentAlignment="Center" Padding="8,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Nueva Contraseña" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPassNueva" Height="35" VerticalContentAlignment="Center" Padding="8,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Confirmar Nueva Contraseña" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPassConfirmar" Height="35" VerticalContentAlignment="Center" Padding="8,0"/>
                </StackPanel>

                <Border x:Name="brdError" Background="#FDEDEC" CornerRadius="5" Padding="10" Margin="0,10,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="lblError" Text="Error" Foreground="#CB4335" FontSize="11" TextAlignment="Center" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Button x:Name="btnActualizar" Content="Actualizar Contraseña" Height="42"
                        Background="#27AE60" Foreground="White" FontWeight="Bold" FontSize="14"
                        Click="btnActualizar_Click" Cursor="Hand" BorderThickness="0" IsDefault="True">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>