<Window x:Class="Vetcare.Presentacion.WindowSelectorMascota"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar Mascota" Height="500" Width="650"
        WindowStartupLocation="CenterOwner" Background="#F4F6F7">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="FILTRAR POR NOMBRE, ESPECIE O DUEÑO" FontSize="10" FontWeight="Bold" Foreground="#7F8C8D"/>
                <TextBox x:Name="txtBuscaMascota" Height="25" Margin="0,5,0,0" TextChanged="txtBuscaMascota_TextChanged"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="5">
            <DataGrid x:Name="dgMascotas" AutoGenerateColumns="False" IsReadOnly="True" 
                      CanUserAddRows="False" GridLinesVisibility="None" HeadersVisibility="Column"
                      MouseDoubleClick="dgMascotas_MouseDoubleClick" SelectionMode="Single"
                      Background="White" BorderThickness="0" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="NOMBRE" Binding="{Binding Nombre}" Width="2*"/>
                    <DataGridTextColumn Header="ESPECIE" Binding="{Binding NombreEspecie}" Width="2*"/>
                    <DataGridTextColumn Header="RAZA" Binding="{Binding NombreRaza}" Width="2*"/>
                    <DataGridTextColumn Header="DUEÑO" Binding="{Binding NombreDueno}" Width="3*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancelar" Click="btnCancelar_Click" Width="100" Height="30" Margin="0,0,10,0" Background="#BDC3C7" BorderThickness="0"/>
            <Button Content="Seleccionar" Click="btnSeleccionar_Click" Width="120" Height="30" Background="#E67E22" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>