<UserControl x:Class="Vetcare.Presentacion.Clientes.UC_MascotasCliente"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:util="clr-namespace:Vetcare.Entidades"
             Background="White" FontFamily="Segoe UI">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,30">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Mascotas" FontSize="28" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Animales registrados a nombre de este cliente" Foreground="#7F8C8D" FontSize="14"/>
            </StackPanel>

            <Button DockPanel.Dock="Right" 
            x:Name="btnAnadirMascota"
            Content="+ Añadir Mascota" 
            Click="btnAnadirMascota_Click"
            Background="#27AE60" Foreground="White" 
            Width="160" Height="45" FontWeight="Bold" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Source={x:Static util:Sesion.UsuarioActual}, Path=IdRol}" Value="2">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DockPanel>

        <DataGrid x:Name="dgMascotas" Grid.Row="1" MouseDoubleClick="dgMascotas_MouseDoubleClick"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  HeadersVisibility="Column" 
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F2F2F2"
                  Background="Transparent" BorderThickness="0"
                  FontSize="16" RowHeight="55">

            <DataGrid.Resources>
                <Style TargetType="DataGridCell">
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="10,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                    <ContentPresenter VerticalAlignment="Center" Margin="10,0"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#EBF5FB"/>
                            <Setter Property="Foreground" Value="#2C3E50"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="10,0,10,10"/>
                    <Setter Property="Foreground" Value="#95A5A6"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#F2F2F2"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="ESTADO" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border x:Name="brdEstado" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                <TextBlock x:Name="txtEstado"
                           FontSize="11"
                           FontWeight="Bold"
                           TextAlignment="Center"/>
                            </Border>

                            <DataTemplate.Triggers>
                                <!-- ACTIVO -->
                                <DataTrigger Binding="{Binding Activo}" Value="True">
                                    <Setter TargetName="brdEstado" Property="Background" Value="#EAFAF1"/>
                                    <Setter TargetName="txtEstado" Property="Foreground" Value="#27AE60"/>
                                    <Setter TargetName="txtEstado" Property="Text" Value="Activo"/>
                                </DataTrigger>

                                <!-- INACTIVO -->
                                <DataTrigger Binding="{Binding Activo}" Value="False">
                                    <Setter TargetName="brdEstado" Property="Background" Value="#FDEDEC"/>
                                    <Setter TargetName="txtEstado" Property="Foreground" Value="#CB4335"/>
                                    <Setter TargetName="txtEstado" Property="Text" Value="Inactivo"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="NOMBRE" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center">
                    <Hyperlink Click="HyperlinkMascota_Click" Foreground="#3498DB" FontWeight="Bold" TextDecorations="None">
                        <Run Text="{Binding Nombre}"/>
                    </Hyperlink>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="ESPECIE" Binding="{Binding NombreEspecie}" Width="*"/>
                <DataGridTextColumn Header="RAZA" Binding="{Binding NombreRaza}" Width="*"/>

                <DataGridTemplateColumn Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Ver ficha" 
                        Click="HyperlinkMascota_Click"
                        Background="#1ABC9C" 
                        Foreground="White"
                        BorderThickness="0"
                        Height="30"
                        Width="110"
                        Cursor="Hand"
                        FontWeight="SemiBold"
                        FontSize="13">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="15">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border x:Name="pnlSinMascotas" 
        Grid.Row="1" 
        Background="#F9FAFB" 
        CornerRadius="10" 
        Margin="0,10,0,0"
        Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🐾" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10" Opacity="0.7"/>

                <TextBlock Text="No hay mascotas registradas" 
                   FontSize="18" 
                   FontWeight="SemiBold" 
                   Foreground="#2C3E50" 
                   HorizontalAlignment="Center"/>

                <TextBlock Text="Este cliente aún no tiene mascotas vinculadas." 
                   FontSize="13" 
                   Foreground="#7F8C8D" 
                   HorizontalAlignment="Center" 
                   Margin="0,5,0,20"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>