<Window x:Class="Vetcare.Presentacion.Mascotas.Razas.WindowRaza"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva Raza" Height="260" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F4F6F7">

    <!-- Contenedor principal de la ventana -->
    <Grid Margin="25">

        <!-- Estructura vertical de elementos -->
        <StackPanel>

            <!-- Título principal -->
            <TextBlock Text="REGISTRAR NUEVA RAZA" FontSize="16" FontWeight="Bold" Foreground="#1B2631"/>

            <!-- Línea decorativa -->
            <Rectangle Height="2" Fill="#2ECC71" HorizontalAlignment="Left" Width="40" Margin="2,5,0,25"/>

            <!-- Etiqueta del campo -->
            <TextBlock Text="NOMBRE DE LA RAZA" FontSize="10" FontWeight="Bold" Foreground="#7F8C8D" Margin="0,0,0,5"/>

            <!-- Input de nombre de raza -->
            <TextBox x:Name="txtNombreRaza" Height="30" VerticalContentAlignment="Center" 
                     Padding="8,0" Foreground="Black" FontWeight="SemiBold"/>

            <!-- Botonera inferior -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">

                <!-- Botón cancelar -->
                <Button Content="Cancelar" Click="BtnCancelar_Click" Width="90" Height="30" 
                        Background="#BDC3C7" BorderThickness="0" Margin="0,0,10,0"/>

                <!-- Botón guardar -->
                <Button Content="Guardar Raza" Click="BtnGuardar_Click" Width="110" Height="30" 
                        Background="#2ECC71" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

            </StackPanel>

        </StackPanel>

    </Grid>
</Window>