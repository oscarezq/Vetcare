<Window x:Class="Vetcare.Presentacion.Mascotas.Razas.WindowSelectorRaza"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vetcare.Presentacion.Mascotas.Razas"
        mc:Ignorable="d"
        Title="Seleccionar Raza" Height="500" Width="500"
        WindowStartupLocation="CenterOwner" Background="#F4F6F7">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="RAZAS" FontSize="18" FontWeight="Bold" Foreground="#1B2631"/>
                <Rectangle Height="2" Fill="#2ECC71" HorizontalAlignment="Left" Width="40" Margin="2,3,0,0"/>
            </StackPanel>

            <Button Content="+ Nueva Raza" Click="btnNuevaRaza_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Width="110" Height="30" Background="#2ECC71" 
                    Foreground="White" FontWeight="Bold" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="FILTRAR POR NOMBRE DE RAZA" FontSize="10" FontWeight="Bold" Foreground="#7F8C8D"/>
                <TextBox x:Name="txtBuscaRaza" Height="28" Margin="0,5,0,0" 
                         TextChanged="txtBuscaRaza_TextChanged"
                         VerticalContentAlignment="Center" Padding="5,0"
                         Foreground="Black" Background="White"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="5">
            <DataGrid x:Name="dgRazas" AutoGenerateColumns="False" IsReadOnly="True" 
                      CanUserAddRows="False" GridLinesVisibility="None" HeadersVisibility="Column"
                      MouseDoubleClick="dgRazas_MouseDoubleClick" SelectionMode="Single"
                      Background="White" BorderThickness="0" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="RAZA" Binding="{Binding NombreRaza}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="5,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="ESPECIE" Binding="{Binding NombreEspecie}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#7F8C8D"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="5,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancelar" Click="btnCancelar_Click" Width="90" Height="30" Margin="0,0,10,0" 
                    Background="#BDC3C7" Foreground="Black" BorderThickness="0"/>

            <Button Content="Seleccionar" Click="btnSeleccionar_Click" Width="110" Height="30" 
                    Background="#2ECC71" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>