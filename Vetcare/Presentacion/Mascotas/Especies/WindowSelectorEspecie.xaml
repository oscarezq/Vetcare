<Window x:Class="Vetcare.Presentacion.Mascotas.Especies.WindowSelectorEspecie"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar Especie" Height="450" Width="450"
        WindowStartupLocation="CenterOwner" Background="#F4F6F7">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="ESPECIES" FontSize="18" FontWeight="Bold" Foreground="#1B2631"/>
                <Rectangle Height="2" Fill="#2ECC71" HorizontalAlignment="Left" Width="40" Margin="2,3,0,0"/>
            </StackPanel>

            <Button Content="+ Nueva Especie" Click="btnNuevaEspecie_Click" 
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Width="110" Height="30" Background="#2ECC71" 
                    Foreground="White" FontWeight="Bold" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="FILTRAR POR NOMBRE DE ESPECIE" FontSize="10" FontWeight="Bold" Foreground="#7F8C8D"/>
                <TextBox x:Name="txtBuscaEspecie" Height="28" Margin="0,5,0,0" 
                         TextChanged="txtBuscaEspecie_TextChanged" 
                         VerticalContentAlignment="Center" Padding="5,0"
                         Foreground="Black" Background="White"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="5">
            <DataGrid x:Name="dgEspecies" AutoGenerateColumns="False" IsReadOnly="True" 
                      CanUserAddRows="False" GridLinesVisibility="None" HeadersVisibility="Column"
                      MouseDoubleClick="dgEspecies_MouseDoubleClick" SelectionMode="Single"
                      Background="White" BorderThickness="0" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="NOMBRE DE ESPECIE" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding NombreEspecie}" Foreground="Black" VerticalAlignment="Center" Margin="10,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancelar" Click="btnCancelar_Click" Width="90" Height="30" Margin="0,0,10,0" 
                    Background="#BDC3C7" Foreground="Black" BorderThickness="0"/>

            <Button Content="Seleccionar" Click="btnSeleccionar_Click" Width="110" Height="30" 
                    Background="#2ECC71" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>