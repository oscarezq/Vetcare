<Window x:Class="Vetcare.Presentacion.Mascotas.Especies.WindowNuevaEspecie"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva Especie" Height="260" Width="380"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize" 
        Background="#F4F6F7"
        Icon="/Resources/icono.png">

    <Grid Margin="25">
        <StackPanel>
            <TextBlock Text="REGISTRAR NUEVA ESPECIE" FontSize="16" FontWeight="Bold" Foreground="#1B2631"/>
            <Rectangle Height="2" Fill="#2ECC71" HorizontalAlignment="Left" Width="40" Margin="2,5,0,25"/>

            <TextBlock Text="NOMBRE DE LA ESPECIE" FontSize="10" FontWeight="Bold" Foreground="#7F8C8D" Margin="0,0,0,5"/>

            <TextBox x:Name="txtNombre" 
                     Height="30" 
                     VerticalContentAlignment="Center" 
                     Padding="8,0" 
                     Foreground="Black" 
                     FontWeight="SemiBold"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                <Button Content="Cancelar" 
                        Click="btnCancelar_Click" 
                        Width="90" 
                        Height="30" 
                        Background="#BDC3C7" 
                        BorderThickness="0" 
                        Margin="0,0,10,0"/>

                <Button Content="Guardar Especie" 
                        Click="btnGuardar_Click" 
                        Width="120" 
                        Height="30" 
                        Background="#2ECC71" 
                        Foreground="White" 
                        FontWeight="Bold" 
                        BorderThickness="0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>