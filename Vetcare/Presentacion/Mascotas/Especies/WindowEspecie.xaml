<Window x:Class="Vetcare.Presentacion.Mascotas.Especies.WindowNuevaEspecie"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva Especie" Height="180" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8F9F9" Icon="/Resources/icono.png">

    <Border Padding="20">
        <StackPanel>
            <TextBlock Text="Nombre de la especie:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNombre" Height="30" Padding="5" VerticalContentAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancelar" Width="90" Margin="5,0" Click="btnCancelar_Click"/>
                <Button Content="Guardar" Width="90" Margin="5,0" Click="btnGuardar_Click" Background="#E67E22" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>