<Window x:Class="Vetcare.Presentacion.WindowFichaMascota"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ficha de Mascota"
        Height="560"
        Width="1000"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#ECF0F1">

    <Window.Resources>

        <!-- Estilo botones menú lateral -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="20,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#34495E"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1ABC9C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo botón editar -->
        <Style x:Key="EditButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo etiquetas -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="Gray"/>
        </Style>

        <!-- Estilo valores -->
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,2,0,12"/>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2C3E50" Grid.Column="0">
            <StackPanel Margin="0,40,0,0">

                <TextBlock TextAlignment="Center"
                           Margin="20,0,20,40"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           TextWrapping="Wrap">
                    <Run Text="Ficha de"/>
                    <Run Text="{Binding Nombre}"/>
                </TextBlock>

                <Button x:Name="btnDatos"
                        Content="Datos de la Mascota"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="btnDatos_Click"/>

                <Button x:Name="btnHistorial"
                        Content="Historial Clínico"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="btnHistorial_Click"/>

            </StackPanel>
        </Border>

        <!-- ================= CONTENIDO ================= -->
        <Grid Grid.Column="1" Background="White">

            <!-- PANEL DATOS -->
            <Grid x:Name="panelDatos" Margin="60">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Título + editar -->
                <DockPanel Margin="0,0,0,35">
                    <TextBlock Text="Datos de la Mascota"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#2C3E50"
                               DockPanel.Dock="Left"/>

                    <Button x:Name="btnEditarMascota"
                            Content="Editar Datos"
                            Style="{StaticResource EditButtonStyle}"
                            DockPanel.Dock="Right"
                            Click="btnEditarMascota_Click"/>
                </DockPanel>

                <!-- GRID 2 COLUMNAS -->
                <Grid Grid.Row="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ===== COLUMNA IZQUIERDA ===== -->
                    <StackPanel Grid.Column="0">

                        <TextBlock Text="Nombre" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Nombre}" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="Número de chip" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding NumeroChip}" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="Especie" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Especie}" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="Raza" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Raza}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <!-- ===== COLUMNA DERECHA ===== -->
                    <StackPanel Grid.Column="1" Margin="40,0,0,0">
                        <TextBlock Text="Dueño" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Style="{StaticResource ValueStyle}">
                            <Hyperlink Click="HyperlinkDueno_Click" Foreground="#2E86C1" TextDecorations="{x:Null}">
                                <Run Text="{Binding Dueno, Mode=OneWay}"/>
                            </Hyperlink>
                        </TextBlock>

                        <TextBlock Text="Sexo" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Sexo}" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="Peso" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Peso}" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="Fecha de Nacimiento" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding FechaNacimiento, StringFormat=dd/MM/yyyy}"
                                   Style="{StaticResource ValueStyle}"/>

                    </StackPanel>

                </Grid>
            </Grid>

            <!-- PANEL HISTORIAL -->
            <Grid x:Name="panelHistorial"
                  Visibility="Collapsed"
                  Margin="60">

                <TextBlock Text="Historial Clínico"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#2C3E50"/>

            </Grid>

        </Grid>
    </Grid>
</Window>