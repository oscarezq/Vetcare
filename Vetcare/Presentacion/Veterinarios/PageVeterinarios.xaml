<Page x:Class="Vetcare.Presentacion.Veterinarios.PageVeterinarios"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1100"
      Title="PageVeterinarios">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderBrush="#D5DBDB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="BUSCAR POR CAMPO" FontSize="11" FontWeight="Bold" Foreground="#E67E22" Margin="5,0,0,10"/>

                <UniformGrid Columns="4" Margin="0,0,0,15">
                    <UniformGrid.Resources>
                        <Style TargetType="TextBox">
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="5,0"/>
                        </Style>
                    </UniformGrid.Resources>

                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Nombre" FontSize="10" Foreground="#7F8C8D"/>
                        <TextBox x:Name="txtBuscaNombre" TextChanged="FiltroAvanzado_Changed"/>
                    </StackPanel>

                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Apellidos" FontSize="10" Foreground="#7F8C8D"/>
                        <TextBox x:Name="txtBuscaApellidos" TextChanged="FiltroAvanzado_Changed"/>
                    </StackPanel>

                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Especialidad" FontSize="10" Foreground="#7F8C8D"/>
                        <TextBox x:Name="txtBuscaEspecialidad" TextChanged="FiltroAvanzado_Changed"/>
                    </StackPanel>

                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Nº Colegiado" FontSize="10" Foreground="#7F8C8D"/>
                        <TextBox x:Name="txtBuscaNumeroColegiado" TextChanged="FiltroAvanzado_Changed"/>
                    </StackPanel>
                </UniformGrid>

                <Separator Background="#EBEDEF" Margin="5,5,5,15"/>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ORDENAR POR:" FontSize="11" FontWeight="Bold" Foreground="#2E86C1" VerticalAlignment="Center" Margin="5,0,15,0"/>

                    <ComboBox x:Name="cbOrdenarPor" Width="150" Height="28" VerticalContentAlignment="Center" SelectionChanged="FiltroAvanzado_Changed">
                        <ComboBoxItem Content="Nombre" IsSelected="True"/>
                        <ComboBoxItem Content="Apellidos"/>
                        <ComboBoxItem Content="Especialidad"/>
                        <ComboBoxItem Content="Nº Colegiado"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                        <RadioButton x:Name="rbAsc" Content="Ascendente" IsChecked="True" Margin="0,0,15,0" Checked="FiltroAvanzado_Changed"/>
                        <RadioButton x:Name="rbDesc" Content="Descendente" Checked="FiltroAvanzado_Changed"/>
                    </StackPanel>

                    <Button Content="Limpiar Filtros"
                            Margin="30,0,0,0"
                            Padding="15,0"
                            Click="BtnLimpiar_Click"
                            Height="28"
                            Cursor="Hand"
                            Background="#F4F6F7"
                            BorderBrush="#D5DBDB"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" BorderBrush="#D5DBDB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,15">
                    <TextBlock Text="Listado de veterinarios"
                               FontSize="20" FontWeight="Bold" Foreground="#2C3E50"
                               VerticalAlignment="Center"/>

                    <Button DockPanel.Dock="Right"
                            x:Name="btnNuevoVeterinario"
                            Content="+ Nuevo Veterinario"
                            Click="BtnNuevoVeterinario_Click"
                            Background="#27AE60"
                            Foreground="White"
                            FontWeight="Bold"
                            Padding="20,0"
                            Height="38"
                            Cursor="Hand"
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </DockPanel>

                <DataGrid x:Name="dgVeterinarios"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          Background="White"
                          FontSize="14"
                          RowHeight="45"
                          ColumnHeaderHeight="40"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          MouseDoubleClick="DgVeterinarios_MouseDoubleClick">

                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black" />

                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="15,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9F9"/>
                            <Setter Property="Foreground" Value="#566573"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="15,0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E67E22"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="#EBEDEF"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F4F6F7"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF5FB"/>
                                    <Setter Property="Foreground" Value="#2E86C1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="USUARIO" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center">
                                        <Hyperlink Click="HlUsuario_Click" Foreground="#2E86C1" TextDecorations="{x:Null}">
                                            <Run Text="{Binding Username}" FontWeight="SemiBold"/>
                                        </Hyperlink>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="NOMBRE" Binding="{Binding Nombre}" Width="1.5*"/>
                        <DataGridTextColumn Header="APELLIDOS" Binding="{Binding Apellidos}" Width="1.8*"/>
                        <DataGridTextColumn Header="ESPECIALIDAD" Binding="{Binding Especialidad}" Width="1.5*"/>
                        <DataGridTextColumn Header="Nº COLEGIADO" Binding="{Binding NumeroColegiado}" Width="1.2*"/>

                        <DataGridTemplateColumn Header="ACCIONES" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="👁" Click="BtnVerDetalle_Click" Margin="2,0" Background="#EBF5FB" Foreground="#2E86C1" Width="35" Height="30" BorderBrush="#AED6F1" Cursor="Hand"/>
                                        <Button Content="✎" Click="BtnEditar_Click" Margin="2,0" Background="#EBF5FB" Foreground="#2E86C1" Width="35" Height="30" BorderBrush="#AED6F1" Cursor="Hand"/>
                                        <Button Content="🗑" Click="BtnEliminar_Click" Margin="2,0" Background="#FDEDEC" Foreground="#CB4335" Width="35" Height="30" BorderBrush="#FADBD8" Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>