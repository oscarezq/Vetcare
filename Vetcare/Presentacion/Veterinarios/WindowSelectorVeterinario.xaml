<Window x:Class="Vetcare.Presentacion.Veterinarios.WindowSelectorVeterinario"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar Veterinario" Height="500" Width="750"
        WindowStartupLocation="CenterOwner" Background="#F4F6F7">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="BUSCAR POR NOMBRE, ESPECIALIDAD O COLEGIADO" FontSize="10" FontWeight="Bold" Foreground="#7F8C8D"/>
                    <TextBox x:Name="txtBuscaVeterinario" Width="400" Height="25" Margin="0,5,0,0" TextChanged="txtBuscaVeterinario_TextChanged"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="5">
            <DataGrid x:Name="dgVeterinarios" AutoGenerateColumns="False" IsReadOnly="True" 
                      CanUserAddRows="False" GridLinesVisibility="None" HeadersVisibility="Column"
                      MouseDoubleClick="dgVeterinarios_MouseDoubleClick" SelectionMode="Single"
                      Background="White" BorderThickness="0" FontSize="13">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="NOMBRE" Binding="{Binding Nombre}" Width="2*"/>
                    <DataGridTextColumn Header="APELLIDOS" Binding="{Binding Apellidos}" Width="2*"/>
                    <DataGridTextColumn Header="ESPECIALIDAD" Binding="{Binding Especialidad}" Width="2*"/>
                    <DataGridTextColumn Header="Nº COLEGIADO" Binding="{Binding NumeroColegiado}" Width="1.5*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancelar" Click="btnCancelar_Click" Width="100" Height="30" Margin="0,0,10,0" Background="#BDC3C7" BorderThickness="0"/>
            <Button Content="Seleccionar" Click="btnSeleccionar_Click" Width="120" Height="30" Background="#E67E22" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>