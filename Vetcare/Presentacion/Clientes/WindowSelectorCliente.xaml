<Window x:Class="Vetcare.Presentacion.Clientes.WindowSelectorCliente"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar Propietario" Height="550" Width="650"
        WindowStartupLocation="CenterOwner" Background="#F4F6F7">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="5,0,5,15" LastChildFill="False">
            <TextBlock Text="BUSCADOR DE CLIENTES" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50" 
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>

            <Button Content="+ NUEVO CLIENTE" 
                    Click="btnNuevoCliente_Click" 
                    DockPanel.Dock="Right" 
                    Background="#1ABC9C" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    Padding="20,5" 
                    BorderThickness="0" 
                    Cursor="Hand"
                    VerticalAlignment="Center">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </DockPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="FILTRAR POR NOMBRE, APELLIDO O DNI" FontSize="10" FontWeight="Bold" Foreground="#7F8C8D"/>
                <TextBox x:Name="txtBuscaCliente" Height="25" Margin="0,5,0,0" 
                         VerticalContentAlignment="Center"
                         TextChanged="txtBuscaCliente_TextChanged"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="5">
            <DataGrid x:Name="dgClientes" AutoGenerateColumns="False" IsReadOnly="True" 
                      CanUserAddRows="False" GridLinesVisibility="None" HeadersVisibility="Column"
                      MouseDoubleClick="dgClientes_MouseDoubleClick" SelectionMode="Single"
                      Background="White" BorderThickness="0" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="DOCUMENTO" Binding="{Binding NumDocumento}" Width="1.5*"/>
                    <DataGridTextColumn Header="NOMBRE" Binding="{Binding Nombre}" Width="2*"/>
                    <DataGridTextColumn Header="APELLIDOS" Binding="{Binding Apellidos}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancelar" Click="btnCancelar_Click" Width="100" Height="30" Margin="0,0,10,0" Background="#BDC3C7" BorderThickness="0"/>
            <Button Content="Seleccionar" Click="btnSeleccionar_Click" Width="120" Height="30" Background="#E67E22" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>