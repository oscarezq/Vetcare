<Window x:Class="Vetcare.Presentacion.Clientes.WindowFichaCliente"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ficha de Cliente"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#ECF0F1">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="20,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#34495E"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1ABC9C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="3,0"/>
        </Style>

        <Style x:Key="EditButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditButtonStyleSmall" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#3498DB"/>
        </Style>

        <Style x:Key="DeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#E74C3C"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="Gray"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,5,0,20"/>
        </Style>

        <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F4F6F7"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#DDE3E8"/>
            <Setter Property="VerticalGridLinesBrush" Value="#DDE3E8"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Background" Value="#F4F6F7"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#DDE3E8"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E8F4FD"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CenterElementStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2C3E50" Grid.Column="0">
            <StackPanel Margin="0,40,0,0">
                <TextBlock TextAlignment="Center" Margin="20,0,20,40" Foreground="White" FontSize="20" FontWeight="Bold" TextWrapping="Wrap">
                    <Run Text="Ficha de"/>
                    <Run Text="{Binding Nombre}"/>
                    <Run Text=" "/><LineBreak/>
                    <Run Text="{Binding Apellidos}"/>
                </TextBlock>

                <Button Content="Datos del Cliente" Style="{StaticResource MenuButtonStyle}" Click="btnDatos_Click"/>
                <Button Content="Mascotas del Cliente" Style="{StaticResource MenuButtonStyle}" Click="btnMascotas_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="White">

            <Grid x:Name="panelDatos" Margin="60" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,35">
                    <TextBlock Text="Datos del Cliente" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" DockPanel.Dock="Left"/>
                    <Button x:Name="btnEditarCliente" Content="Editar Datos" Style="{StaticResource EditButtonStyle}" Width="150" DockPanel.Dock="Right" Click="btnEditarCliente_Click"/>
                </DockPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Nombre" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Nombre}" Style="{StaticResource ValueStyle}"/>
                        <TextBlock Text="Número de documento" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding NumDocumento}" Style="{StaticResource ValueStyle}"/>
                        <TextBlock Text="Dirección" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Direccion}" Style="{StaticResource ValueStyle}"/>
                        <TextBlock Text="Fecha de alta" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding FechaAlta, StringFormat=dd/MM/yyyy}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="40,0,0,0">
                        <TextBlock Text="Apellidos" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Apellidos}" Style="{StaticResource ValueStyle}"/>
                        <TextBlock Text="Teléfono" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Telefono}" Style="{StaticResource ValueStyle}"/>
                        <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Email}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid x:Name="panelMascotas" Visibility="Collapsed" Margin="60">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,20">
                    <TextBlock Text="Mascotas del Cliente" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" DockPanel.Dock="Left"/>
                    <Button Content="Añadir Mascota" Style="{StaticResource EditButtonStyle}" Width="150" DockPanel.Dock="Right" Click="btnAnadirMascota_Click"/>
                </DockPanel>

                <DataGrid x:Name="dgMascotas" 
                          Grid.Row="1" 
                          Style="{StaticResource ModernDataGridStyle}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*" ElementStyle="{StaticResource CenterElementStyle}"/>
                        <DataGridTextColumn Header="Especie" Binding="{Binding Especie}" Width="*" ElementStyle="{StaticResource CenterElementStyle}"/>
                        <DataGridTextColumn Header="Raza" Binding="{Binding Raza}" Width="*" ElementStyle="{StaticResource CenterElementStyle}"/>
                        <DataGridTextColumn Header="Sexo" Binding="{Binding Sexo}" Width="80" ElementStyle="{StaticResource CenterElementStyle}"/>
                        <DataGridTextColumn Header="Nacimiento" Binding="{Binding FechaNacimiento, StringFormat=dd/MM/yyyy}" Width="120" ElementStyle="{StaticResource CenterElementStyle}"/>

                        <DataGridTemplateColumn Header="Acciones" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Content="👁" ToolTip="Ver ficha" Style="{StaticResource EditButtonStyleSmall}" Click="VerFichaMascota_Click"/>
                                        <Button Content="✎" ToolTip="Editar" Style="{StaticResource EditButtonStyleSmall}" Click="EditarMascotaFila_Click"/>
                                        <Button Content="🗑" ToolTip="Eliminar" Style="{StaticResource DeleteButtonStyle}" Click="EliminarMascotaFila_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>