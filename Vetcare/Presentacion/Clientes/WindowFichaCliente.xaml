<Window x:Class="Vetcare.Presentacion.Clientes.WindowFichaCliente"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:util="clr-namespace:Vetcare.Entidades"
        Title="Ficha de Cliente"
        Height="700" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#ECF0F1">

    <!-- Recursos de la ventana: estilos reutilizables -->
    <Window.Resources>
        <!-- Estilo para los botones del menú lateral -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="20,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#34495E"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- Contenedor visual del botón -->
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Cambio de color al pasar el ratón -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1ABC9C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Contenedor principal -->
    <Grid>
        <!-- Definición de columnas: menú lateral + contenido -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menú lateral izquierdo -->
        <Border Background="#2C3E50" Grid.Column="0">
            <StackPanel Margin="0,40,0,0">

                <!-- Información del cliente -->
                <TextBlock TextAlignment="Center" Margin="20,0,20,40" Foreground="White" FontSize="18" FontWeight="Bold" TextWrapping="Wrap">
                    <Run Text="Cliente:"/>
                    <LineBreak/>
                    <!-- Binding al nombre y apellidos -->
                    <Run Text="{Binding Nombre}"/> <Run Text="{Binding Apellidos}"/>
                </TextBlock>

                <!-- Botones de navegación -->
                <Button Content="Datos Personales" Style="{StaticResource MenuButtonStyle}" Click="BtnDatos_Click"/>
                <Button Content="Mascotas" Style="{StaticResource MenuButtonStyle}" Click="BtnMascotas_Click"/>

                <!-- Botón de facturación -->
                <Button x:Name="btnFacturacionMenu"
                        Content="Facturación"
                        Click="BtnFacturas_Click">

                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                            <!-- Ocultar si el usuario logueado es veterinario (Rol 2) -->
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Source={x:Static util:Sesion.UsuarioActual}, Path=IdRol}" Value="2">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                </Button>
            </StackPanel>
        </Border>

        <!-- Contenido dinámico (panel derecho) -->
        <Grid Grid.Column="1" Background="White">
            <!-- Aquí se cargan las vistas dinámicamente -->
            <ContentControl x:Name="ContenedorPrincipal" Margin="10"/>
        </Grid>
    </Grid>
</Window>