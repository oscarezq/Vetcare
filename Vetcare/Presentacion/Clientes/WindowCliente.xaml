<Window x:Class="Vetcare.Presentacion.Clientes.WindowCliente"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ficha de Cliente" Height="540" Width="550" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" 
        Background="#F8F9F9" Icon="/Resources/icono.png">

    <Border Padding="25">
        <StackPanel>
            <StackPanel Margin="0,0,0,25">
                <TextBlock x:Name="lblTitulo" Text="NUEVO CLIENTE" FontSize="20" FontWeight="Bold" Foreground="#1B2631"/>
                <Rectangle Height="2" Fill="#E67E22" HorizontalAlignment="Left" Width="50" Margin="2,5,0,0"/>
            </StackPanel>

            <UniformGrid Columns="2" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <TextBlock Text="Número de documentación" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNumDocumento" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Nombre" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNombre" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>
            </UniformGrid>

            <StackPanel Margin="5,0,5,15">
                <TextBlock Text="Apellidos" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                <TextBox x:Name="txtApellidos" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
            </StackPanel>

            <UniformGrid Columns="2" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <TextBlock Text="Teléfono" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtTelefono" Height="28" VerticalContentAlignment="Center" Padding="5,0" MaxLength="9"/>
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Fecha de Registro" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtFechaAlta" Height="28" IsReadOnly="True" Background="#EBEDEF" 
                             BorderBrush="#D5DBDB" VerticalContentAlignment="Center" Padding="5,0" Foreground="#7F8C8D"/>
                </StackPanel>
            </UniformGrid>

            <StackPanel Margin="5,0,5,15">
                <TextBlock Text="Email" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                <TextBox x:Name="txtEmail" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
            </StackPanel>

            <StackPanel Margin="5,0,5,25">
                <TextBlock Text="Dirección" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                <TextBox x:Name="txtDireccion" Height="28" Padding="5"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,5,0">
                <Button x:Name="btnCancelar" Content="Cancelar" Width="90" Height="32" 
                        Margin="10,0" Click="btnCancelar_Click" Cursor="Hand"
                        Background="#FBFCFC" BorderBrush="#D5DBDB"/>

                <Button x:Name="btnGuardar" Content="Guardar Cliente" Width="130" Height="32" 
                        Background="#E67E22" Foreground="White" FontWeight="Bold" 
                        Click="btnGuardar_Click" Cursor="Hand" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
