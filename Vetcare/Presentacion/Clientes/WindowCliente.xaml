<Window x:Class="Vetcare.Presentacion.Clientes.WindowCliente"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ficha de Cliente" Height="750" Width="1000" 
        WindowStartupLocation="CenterScreen" Background="#F8FAFC"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True" 
        SnapsToDevicePixels="True" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ModernInput" TargetType="Control">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Border Padding="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,30">
                <TextBlock x:Name="lblTitulo" Text="NUEVO CLIENTE" FontSize="26" FontWeight="Bold" Foreground="#2C3E50"/>
                <Rectangle Height="3" Fill="#E67E22" HorizontalAlignment="Left" Width="40" Margin="2,5,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent" Padding="0,0,15,0">
                <StackPanel>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition Width="6*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="TIPO DOCUMENTO" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cmbTipoDocumento" Style="{StaticResource ModernInput}">
                                <ComboBoxItem Content="DNI" IsSelected="True"/>
                                <ComboBoxItem Content="NIE"/>
                                <ComboBoxItem Content="Pasaporte"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="NÚMERO DE DOCUMENTO" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtNumDocumento" Style="{StaticResource ModernInput}">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                    </Grid>

                    <UniformGrid Columns="2" Margin="0,0,0,20">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="NOMBRE" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtNombre" Style="{StaticResource ModernInput}">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="APELLIDOS" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtApellidos" Style="{StaticResource ModernInput}">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,0,0,30">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="TELÉFONO" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtTelefono" Style="{StaticResource ModernInput}" MaxLength="9">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="CORREO ELECTRÓNICO" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtEmail" Style="{StaticResource ModernInput}">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                    </UniformGrid>

                    <Border BorderBrush="#F1F5F9" BorderThickness="0,2,0,0" Margin="0,10,0,25">
                        <TextBlock Text="DIRECCIÓN DE CONTACTO" FontSize="13" FontWeight="Bold" Foreground="#E67E22" Margin="0,15,0,0"/>
                    </Border>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="CALLE / VÍA" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtCalle" Style="{StaticResource ModernInput}">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Nº" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtNumero" Style="{StaticResource ModernInput}">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="PISO/PUERTA" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtPisoPuerta" Style="{StaticResource ModernInput}">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition Width="3.5*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="C. POSTAL" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtCP" Style="{StaticResource ModernInput}" MaxLength="5">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="LOCALIDAD" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtLocalidad" Style="{StaticResource ModernInput}">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="PROVINCIA" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtProvincia" Style="{StaticResource ModernInput}">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" BorderBrush="#F1F5F9" BorderThickness="0,1,0,0" Padding="0,25,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnCancelar" Content="Cancelar" Width="110" Height="45" 
                            Click="btnCancelar_Click" Cursor="Hand" Background="Transparent" 
                            Foreground="#64748B" FontWeight="SemiBold" BorderThickness="0"/>

                    <Button x:Name="btnGuardar" Content="Guardar Cliente" Width="180" Height="45" IsDefault="True"
                            Margin="15,0,0,0" Background="#E67E22" Foreground="White" FontWeight="Bold" 
                            Click="btnGuardar_Click" Cursor="Hand" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>