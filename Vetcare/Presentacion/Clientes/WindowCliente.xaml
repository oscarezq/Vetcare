<Window x:Class="Vetcare.Presentacion.Clientes.WindowCliente"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ficha de Cliente" Height="600" Width="700" 
        WindowStartupLocation="CenterScreen"
        Background="#F8F9F9" Icon="/Resources/icono.png">

    <Border Padding="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock x:Name="lblTitulo" Text="NUEVO CLIENTE" FontSize="22" FontWeight="Bold" Foreground="#1B2631"/>
                <Rectangle Height="3" Fill="#E67E22" HorizontalAlignment="Left" Width="40" Margin="2,5,0,0"/>
            </StackPanel>

            <!-- Contenido -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent">
                <StackPanel Margin="0,0,0,0">

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition Width="6*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Tipo Documento" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cmbTipoDocumento" Height="32" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="DNI"/>
                                <ComboBoxItem Content="NIE"/>
                                <ComboBoxItem Content="Pasaporte"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Número de documento" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtNumDocumento" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                    </Grid>

                    <UniformGrid Columns="2" Margin="0,0,0,15">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Nombre" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtNombre" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Apellidos" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtApellidos" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,0,0,15">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Teléfono" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtTelefono" Height="32" VerticalContentAlignment="Center" Padding="8,0" MaxLength="9"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Correo Electrónico" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtEmail" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock Text="DIRECCIÓN" FontSize="11" FontWeight="Bold" Foreground="#E67E22" Margin="0,10,0,10"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Calle / Vía" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtCalle" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Nº" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtNumero" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Piso/Puerta" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtPisoPuerta" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition Width="3.5*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="C. Postal" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtCP" Height="32" VerticalContentAlignment="Center" Padding="8,0" MaxLength="5"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Localidad" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtLocalidad" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Provincia" FontSize="11" FontWeight="SemiBold" Foreground="#566573" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtProvincia" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Botones -->
            <Border Grid.Row="2" BorderBrush="#EAECEE" BorderThickness="0,1,0,0" Padding="0,20,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnCancelar" Content="Cancelar" Width="100" Height="35" 
                            Click="btnCancelar_Click" Cursor="Hand" Background="Transparent" BorderBrush="#D5DBDB"/>

                    <Button x:Name="btnGuardar" Content="Guardar Cliente" Width="150" Height="35" 
                            Margin="15,0,0,0" Background="#E67E22" Foreground="White" FontWeight="Bold" 
                            Click="btnGuardar_Click" Cursor="Hand" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>