<UserControl x:Class="Vetcare.Presentacion.Clientes.UC_DatosCliente"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,30">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Ficha del Cliente" FontSize="28" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Gestión de información personal y localización" Foreground="#7F8C8D" FontSize="14"/>
            </StackPanel>

            <Button DockPanel.Dock="Right" 
                    Content="Editar Cliente" 
                    Click="btnEditarCliente_Click"
                    Background="#3498DB" Foreground="White" 
                    Width="160" Height="45" FontWeight="Bold" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <UniformGrid Columns="2">
                    <StackPanel Margin="10,0,20,0">
                        <TextBlock Text="NOMBRE" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Nombre}" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="DNI / DOCUMENTO" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding NumDocumento}" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="EMAIL" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Email}" Style="{StaticResource ValueStyle}" Foreground="#3498DB"/>
                    </StackPanel>

                    <StackPanel Margin="10,0">
                        <TextBlock Text="APELLIDOS" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Apellidos}" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="TELÉFONO" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Telefono}" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="FECHA DE ALTA" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding FechaAlta, StringFormat=dd/MM/yyyy}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>
                </UniformGrid>

                <Separator Margin="10,10,10,25" Background="#ECF0F1" Height="1"/>

                <TextBlock Text="DIRECCIÓN DE CONTACTO" FontSize="13" FontWeight="Bold" Foreground="#E67E22" Margin="10,0,0,20"/>

                <UniformGrid Columns="2">
                    <StackPanel Margin="10,0,20,0">
                        <TextBlock Text="CALLE / VÍA" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding CalleDireccion}" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="LOCALIDAD" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding LocalidadDireccion}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="10,0">
                        <TextBlock Text="NÚMERO / PISO / PUERTA" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Style="{StaticResource ValueStyle}">
                            <Run Text="{Binding NumeroDireccion}"/>
                            <Run Text=" - " Foreground="#BDC3C7"/>
                            <Run Text="{Binding PisoPuertaDireccion}"/>
                        </TextBlock>

                        <TextBlock Text="PROVINCIA / CP" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Style="{StaticResource ValueStyle}">
                            <Run Text="{Binding ProvinciaDireccion}"/>
                            <Run Text=" ("/><Run Text="{Binding CodigoPostalDireccion}"/><Run Text=")"/>
                        </TextBlock>
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>