<UserControl x:Class="Vetcare.Presentacion.Clientes.UC_DatosCliente"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:util="clr-namespace:Vetcare.Entidades"
             Background="White" TextOptions.TextFormattingMode="Display" UseLayoutRounding="True" 
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,30"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,35">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Ficha del Cliente" FontSize="28" FontWeight="Bold" Foreground="#2C3E50"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">

                    <Border CornerRadius="4" Padding="8,2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Activo}" Value="True">
                                        <Setter Property="Background" Value="#EAFAF1"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Activo}" Value="False">
                                        <Setter Property="Background" Value="#FDEDEC"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <TextBlock FontSize="10" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Activo}" Value="True">
                                            <Setter Property="Foreground" Value="#27AE60"/>
                                            <Setter Property="Text" Value="ACTIVO"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Activo}" Value="False">
                                            <Setter Property="Foreground" Value="#CB4335"/>
                                            <Setter Property="Text" Value="INACTIVO"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                </StackPanel>
            </StackPanel>

            <Button DockPanel.Dock="Right" 
                    x:Name="btnEditarCliente"
                    Content="Editar Cliente"
                    Click="btnEditarCliente_Click"
                    Background="#3498DB" Foreground="White" 
                    Width="160" Height="45" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Source={x:Static util:Sesion.UsuarioActual}, Path=IdRol}" Value="2">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="DATOS PERSONALES" Style="{StaticResource SectionTitleStyle}"/>
                        <UniformGrid Columns="3">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="NOMBRE" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding Nombre}" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Text="DOCUMENTO" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding NumDocumento}" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="APELLIDOS" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding Apellidos}" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Text="TELÉFONO" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding Telefono}" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="EMAIL" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding Email}" Style="{StaticResource ValueStyle}" Foreground="#3498DB"/>
                                <TextBlock Text="MIEMBRO DESDE" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding FechaAlta, StringFormat=dd/MM/yyyy}" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="DIRECCIÓN DE CONTACTO" Style="{StaticResource SectionTitleStyle}"/>
                        <UniformGrid Columns="3">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="CALLE / VÍA" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding CalleDireccion}" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="NÚMERO" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding NumeroDireccion}" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="PISO / PUERTA" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding PisoPuertaDireccion}" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="LOCALIDAD" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding LocalidadDireccion}" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="PROVINCIA" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding ProvinciaDireccion}" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="CÓDIGO POSTAL" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding CodigoPostalDireccion}" Style="{StaticResource ValueStyle}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>