<Page x:Class="Vetcare.Presentacion.Clientes.PageClientes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:util="clr-namespace:Vetcare.Entidades"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1100"
      Title="PageClientes">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- SECCIÓN DE FILTROS -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderBrush="#D5DBDB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="BUSCAR POR CAMPO" FontSize="11" FontWeight="Bold" Foreground="#E67E22" Margin="5,0,0,10"/>

                <UniformGrid Columns="4" Margin="0,0,0,15">
                    <UniformGrid.Resources>
                        <Style TargetType="TextBox">
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="5,0"/>
                        </Style>
                    </UniformGrid.Resources>

                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Nombre / Apellidos" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtBuscaCliente" TextChanged="FiltroAvanzado_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Documento (DNI/NIE)" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtBuscaNumDocumento" TextChanged="FiltroAvanzado_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Teléfono" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtBuscaTelefono" TextChanged="FiltroAvanzado_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Email" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtBuscaEmail" TextChanged="FiltroAvanzado_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Alta - Desde" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <DatePicker x:Name="dtpBuscaFechaDesde" Height="28" VerticalContentAlignment="Center" SelectedDateChanged="FiltroAvanzado_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Alta - Hasta" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <DatePicker x:Name="dtpBuscaFechaHasta" Height="28" VerticalContentAlignment="Center" SelectedDateChanged="FiltroAvanzado_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="5,5,5,0">
                        <TextBlock Text="Estado" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <ComboBox x:Name="cbBuscaEstado" Height="28" VerticalContentAlignment="Center" SelectionChanged="FiltroAvanzado_Changed">
                            <ComboBoxItem Content="Todos"/>
                            <ComboBoxItem Content="Activo" IsSelected="True"/>
                            <ComboBoxItem Content="Inactivo"/>
                        </ComboBox>
                    </StackPanel>
                </UniformGrid>

                <Separator Background="#EBEDEF" Margin="5,5,5,15"/>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ORDENAR POR:" FontSize="11" FontWeight="Bold" Foreground="#2E86C1" VerticalAlignment="Center" Margin="5,0,15,0"/>
                    <ComboBox x:Name="cbOrdenarPor" Width="150" Height="28" VerticalContentAlignment="Center" SelectionChanged="FiltroAvanzado_Changed">
                        <ComboBoxItem Content="Fecha de Alta" IsSelected="True"/>
                        <ComboBoxItem Content="DNI"/>
                        <ComboBoxItem Content="Nombre"/>
                        <ComboBoxItem Content="Apellidos"/>
                        <ComboBoxItem Content="Teléfono"/>
                        <ComboBoxItem Content="Email"/>
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                        <RadioButton x:Name="rbAsc" Content="Ascendente" IsChecked="True" Margin="0,0,15,0" Checked="FiltroAvanzado_Changed"/>
                        <RadioButton x:Name="rbDesc" Content="Descendente" Checked="FiltroAvanzado_Changed"/>
                    </StackPanel>
                    <Button Content="Limpiar Filtros" Margin="30,0,0,0" Padding="15,0" Click="BtnLimpiar_Click" Height="28" Cursor="Hand" Background="#F4F6F7" BorderBrush="#D5DBDB"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- SECCIÓN DE LISTADO -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" BorderBrush="#D5DBDB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,15">
                    <TextBlock Text="Listado de clientes" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>

                    <!-- Botoón de nueva cita -->
                    <Button DockPanel.Dock="Right" x:Name="btnNuevoCliente" Content="+ Nuevo Cliente" Click="BtnNuevoCliente_Click"
                            Background="#27AE60" Foreground="White" FontWeight="Bold" Padding="20,0" Height="38" Cursor="Hand" BorderThickness="0" Margin="10,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <!-- Ocultar si es Veterinario (2) -->
                                    <DataTrigger Binding="{Binding Source={x:Static util:Sesion.UsuarioActual}, Path=IdRol}" Value="2">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </DockPanel>

                <!-- DataGrid con los clientes -->
                <DataGrid x:Name="dgClientes" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" MouseDoubleClick="DgClientes_MouseDoubleClick" 
                          GridLinesVisibility="None" BorderThickness="0" HeadersVisibility="Column" CanUserSortColumns="False" CanUserReorderColumns="False" Background="White" 
                          FontSize="14" RowHeight="45" ColumnHeaderHeight="40" SelectionMode="Extended" SelectionUnit="FullRow" HorizontalScrollBarVisibility="Auto" CanUserResizeColumns="False">

                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black" />
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="Transparent" BorderThickness="0" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style x:Key="HeaderStyleComun" TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9F9"/>
                            <Setter Property="Foreground" Value="#566573"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E67E22"/>
                        </Style>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyleComun}"/>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="#EBEDEF"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F4F6F7"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF5FB"/>
                                    <Setter Property="Foreground" Value="#2E86C1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="ESTADO" Width="100">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyleComun}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="brdEstado" CornerRadius="10" Padding="8,3" HorizontalAlignment="Center">
                                        <TextBlock x:Name="txtEstado" Text="{Binding ActivoTexto}" FontSize="11" FontWeight="Bold" TextAlignment="Center"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Activo}" Value="True">
                                            <Setter TargetName="brdEstado" Property="Background" Value="#EAFAF1"/>
                                            <Setter TargetName="txtEstado" Property="Foreground" Value="#27AE60"/>
                                            <Setter TargetName="txtEstado" Property="Text" Value="Activo"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Activo}" Value="False">
                                            <Setter TargetName="brdEstado" Property="Background" Value="#FDEDEC"/>
                                            <Setter TargetName="txtEstado" Property="Foreground" Value="#CB4335"/>
                                            <Setter TargetName="txtEstado" Property="Text" Value="Inactivo"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="DOCUMENTO" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center">
                                        <Hyperlink Click="BtnVerFichaCliente_Click" Foreground="#2E86C1" TextDecorations="{x:Null}">
                                            <Run Text="{Binding NumDocumento}" FontWeight="SemiBold"/>
                                        </Hyperlink>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="NOMBRE" Binding="{Binding Nombre}" Width="*" />
                        <DataGridTextColumn Header="APELLIDOS" Binding="{Binding Apellidos}" Width="*" />
                        <DataGridTextColumn Header="TELÉFONO" Binding="{Binding Telefono}" Width="110" />
                        <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="1.5*" />
                        <DataGridTextColumn Header="FECHA ALTA" Binding="{Binding FechaAlta, StringFormat=\{0:dd/MM/yyyy\}}" Width="110" />

                        <DataGridTemplateColumn Header="ACCIONES" Width="150">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyleComun}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <!-- Ver detalle -->
                                        <Button x:Name="btnDetalles" Content="👁" ToolTip="Ver Detalle" Click="BtnVerDetalle_Click" Margin="2,0" 
                                                Background="#EBF5FB" Foreground="#2E86C1" Width="35" Height="30" BorderBrush="#AED6F1" Cursor="Hand"/>

                                        <!-- Editar -->
                                        <Button x:Name="btnEditar" Content="✎" ToolTip="Editar" Click="BtnEditar_Click" Margin="2,0" 
                                                Background="#EBF5FB" Foreground="#2E86C1" Width="35" Height="30" BorderBrush="#AED6F1" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <!-- Ocultar si el cliente no está activo o si es Veterinario (2) -->
                                                        <DataTrigger Binding="{Binding Activo}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Source={x:Static util:Sesion.UsuarioActual}, Path=IdRol}" Value="2">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- Dar de baja -->
                                        <Button x:Name="btnEliminar" Content="❌" ToolTip="Dar de baja" Click="BtnEliminar_Click" Margin="2,0" 
                                                Background="#FDEDEC" Foreground="#CB4335" Width="35" Height="30" BorderBrush="#FADBD8" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <!-- Ocultar si el cliente no está activo o si el usuario es Veterinario (2) -->
                                                        <DataTrigger Binding="{Binding Activo}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Source={x:Static util:Sesion.UsuarioActual}, Path=IdRol}" Value="2">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- Reactivar -->
                                        <Button x:Name="btnReactivar" Content="🔁" ToolTip="Reactivar" Click="BtnReactivar_Click" Margin="2,0" 
                                                Background="#EBF5FB" Foreground="#27AE60" Width="35" Height="30" BorderBrush="#A9DFBF" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <!-- Ocultar si el cliente no está activo o si el usuario es Veterinario (2) -->
                                                        <DataTrigger Binding="{Binding Activo}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Source={x:Static util:Sesion.UsuarioActual}, Path=IdRol}" Value="2">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>