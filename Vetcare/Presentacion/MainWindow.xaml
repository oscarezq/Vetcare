<Window x:Class="Vetcare.Presentacion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VetCare" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True" 
        Icon="/Resources/icono.ico" WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F8F9F9"/>
            <Setter Property="Foreground" Value="#1B2631"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="15,5,15,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#EAECEE"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0,0,0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBEDEF"/>
                    <Setter Property="BorderBrush" Value="#E67E22"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D5DBDB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Style.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Padding" Value="10,10"/>
                    <Setter Property="FontSize" Value="13"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="HeaderUserButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2F4F4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2C3E50" Grid.Column="0" BorderBrush="#D5DBDB" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Image Grid.Row="0" Source="/Resources/logo3-transparente.png" 
                       Width="160" Margin="20,25"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel>
                        <Button Style="{StaticResource MenuButtonStyle}" Click="btnInicio_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/home.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="INICIO"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButtonStyle}" Click="btnMascotas_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/clientes.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="MASCOTAS"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButtonStyle}" Click="btnClientes_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/clientes.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="CLIENTES"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButtonStyle}" Click="btnCitas_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/calendario.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="CITAS"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButtonStyle}" Click="btnUsuarios_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/usuarios.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="USUARIOS"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButtonStyle}" Click="btnVeterinarios_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/doctor.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="VETERINARIOS"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButtonStyle}" Click="btnServicios_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/doctor.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="SERVICIOS"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButtonStyle}" Click="btnProductos_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/doctor.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="PRODUCTOS"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButtonStyle}" Click="btnFacturas_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/doctor.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="FACTURAS"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#F4F6F7">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#D5DBDB" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                        <Button x:Name="btnPerfil" Style="{StaticResource HeaderUserButtonStyle}" Click="btnPerfil_Click">
                            <Button.ContextMenu>
                                <ContextMenu Style="{StaticResource ModernContextMenu}">
                                    <MenuItem Header="Mi perfil" Click="btnVerInfo_Click"/>
                                    <MenuItem Header="Cambiar Contraseña" Click="btnCambiarPass_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Cerrar Sesión" Click="btnSalir_Click" Foreground="#E67E22" FontWeight="Bold"/>
                                </ContextMenu>
                            </Button.ContextMenu>

                            <StackPanel Orientation="Horizontal">
                                <Border Width="30" Height="30" CornerRadius="15" Background="#F2F4F4" Margin="0,0,10,0">
                                    <Image Source="/Resources/usuarios.png" Width="14" Height="14" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="lblNombreUsuario" Text="Usuario" 
                                               FontSize="12" FontWeight="Bold" Foreground="#1B2631"/>
                                </StackPanel>

                                <TextBlock Text="▾" VerticalAlignment="Center" Foreground="#ABB2B9" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <Frame x:Name="FramePrincipal" Grid.Row="1" NavigationUIVisibility="Hidden" Margin="15"/>
        </Grid>
    </Grid>
</Window>