<Window x:Class="Vetcare.Presentacion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VetCare" Height="600" Width="999"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True" Icon="/Resources/icono.ico" WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F8F9F9"/>
            <Setter Property="Foreground" Value="#1B2631"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="15,5,15,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#EAECEE"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0,0,0"/>

            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBEDEF"/>
                    <Setter Property="BorderBrush" Value="#E67E22"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2C3E50" Grid.Column="0" BorderBrush="#D5DBDB" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Image Grid.Row="0" Source="/Resources/logo3-transparente.png" 
                       Width="160" Margin="20,20,19,20"
                       RenderOptions.BitmapScalingMode="HighQuality" Height="55"/>

                <StackPanel Grid.Row="1">
                    <Button x:Name="btnInicio" Style="{StaticResource MenuButtonStyle}" Click="btnInicio_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/home.png" Width="18" Margin="0,0,10,0"/>
                            <TextBlock Text="INICIO"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnMascotas" Style="{StaticResource MenuButtonStyle}" Click="btnMascotas_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/clientes.png" Width="18" Margin="0,0,10,0"/>
                            <TextBlock Text="MASCOTAS"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnClientes" Style="{StaticResource MenuButtonStyle}" Click="btnClientes_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/clientes.png" Width="18" Margin="0,0,10,0"/>
                            <TextBlock Text="CLIENTES"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnCitas" Style="{StaticResource MenuButtonStyle}" Click="btnCitas_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/calendario.png" Width="18" Margin="0,0,10,0"/>
                            <TextBlock Text="CITAS"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnHistorial" Style="{StaticResource MenuButtonStyle}" Click="btnHistorial_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/historial.png" Width="18" Margin="0,0,10,0"/>
                            <TextBlock Text="HISTORIAL"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnUsuarios" Style="{StaticResource MenuButtonStyle}" Click="btnUsuarios_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/usuarios.png" Width="18" Margin="0,0,10,0"/>
                            <TextBlock Text="USUARIOS"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnVeterinarios" Style="{StaticResource MenuButtonStyle}" Click="btnVeterinarios_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/doctor.png" Width="18" Margin="0,0,10,0"/>
                            <TextBlock Text="VETERINARIOS"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#F4F6F7">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#D5DBDB" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">

                    <Image Source="/Resources/usuarios.png" Width="14" Height="14" 
                   Margin="0,0,8,0" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

                    <TextBlock Text="Admin" 
                       VerticalAlignment="Center" 
                       FontSize="12"
                       FontWeight="SemiBold" 
                       Foreground="#1B2631"/>

                    <Rectangle Width="1" Height="20" Fill="#D5DBDB" Margin="15,0"/>

                    <Button x:Name="btnSalirHeader" Content="Cerrar Sesión" 
                    FontSize="11" Background="Transparent" BorderThickness="0" 
                    Foreground="#E67E22" VerticalAlignment="Center" 
                    Cursor="Hand" Click="btnSalir_Click"/>
                </StackPanel>
            </Border>

            <Frame x:Name="FramePrincipal" Grid.Row="1" NavigationUIVisibility="Hidden" Margin="15"/>
        </Grid>
    </Grid>
</Window>