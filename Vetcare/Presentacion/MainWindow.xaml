<Window x:Class="Vetcare.Presentacion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:util="clr-namespace:Vetcare.Entidades"
        mc:Ignorable="d"
        Title="VetCare" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True" 
        Icon="/Resources/icono.ico" WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BDC3C7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="15,5,15,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="0">
                            <Grid>
                                <Rectangle x:Name="Indicator" 
                                           HorizontalAlignment="Left" 
                                           Width="4" 
                                           Fill="#E67E22" 
                                           Visibility="Collapsed" 
                                           Margin="2,10,0,10"
                                           RadiusX="2" RadiusY="2"/>

                                <ContentPresenter HorizontalAlignment="Left" 
                                                  VerticalAlignment="Center" 
                                                  Margin="15,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#34495E"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="border" Property="Background" Value="#3E5871"/>
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderUserButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#F2F4F4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D5DBDB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Padding" Value="10,10"/>
                    <Setter Property="FontSize" Value="13"/>
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2C3E50" Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnInicio_Click"
                        Cursor="Hand"
                        Focusable="False">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>

                    <Image Source="/Resources/logo3-transparente.png"
                           Width="160"
                           Margin="20,25"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel x:Name="pnlMenu">
                        <Button x:Name="btnInicio" Style="{StaticResource MenuButtonStyle}" Tag="Selected" Click="BtnInicio_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/home.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="INICIO"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnMascotas" Style="{StaticResource MenuButtonStyle}" Click="BtnMascotas_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/pata.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="MASCOTAS"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnClientes" Style="{StaticResource MenuButtonStyle}" Click="BtnClientes_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/clientes.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="CLIENTES"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnCitas" Style="{StaticResource MenuButtonStyle}" Click="BtnCitas_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/calendario.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="CITAS"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnUsuarios" Click="BtnUsuarios_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Source={x:Static util:Sesion.UsuarioActual}, Path=IdRol}" Value="2">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Source={x:Static util:Sesion.UsuarioActual}, Path=IdRol}" Value="3">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/usuarios.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="USUARIOS"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnServicios" Style="{StaticResource MenuButtonStyle}" Click="BtnServicios_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/servicios.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="SERVICIOS"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnProductos" Style="{StaticResource MenuButtonStyle}" Click="BtnProductos_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/productos.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="PRODUCTOS"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnFacturas" Click="BtnFacturas_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Source={x:Static util:Sesion.UsuarioActual}, Path=IdRol}" Value="2">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/facturas.png" Width="18" Margin="0,0,10,0"/>
                                <TextBlock Text="FACTURAS"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#F4F6F7">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#D5DBDB" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnPerfil" Style="{StaticResource HeaderUserButtonStyle}" Click="BtnPerfil_Click">
                            <Button.ContextMenu>
                                <ContextMenu Style="{StaticResource ModernContextMenu}">
                                    <MenuItem Header="Mi perfil" Click="BtnVerInfo_Click"/>
                                    <MenuItem Header="Cambiar Contraseña" Click="BtnCambiarPass_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Cerrar Sesión" Click="BtnSalir_Click" Foreground="#E67E22" FontWeight="Bold"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="30" Height="30" CornerRadius="15" Background="#F2F4F4" Margin="0,0,10,0">
                                    <Image Source="/Resources/perfil.png" Width="16" Height="16"/>
                                </Border>
                                <TextBlock x:Name="lblNombreUsuario" Text="Usuario" VerticalAlignment="Center" FontWeight="Bold" Foreground="#1B2631"/>
                                <TextBlock Text="▾" VerticalAlignment="Center" Foreground="#ABB2B9" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Frame x:Name="FramePrincipal" Grid.Row="1" NavigationUIVisibility="Hidden" Margin="15"/>
        </Grid>
    </Grid>
</Window>