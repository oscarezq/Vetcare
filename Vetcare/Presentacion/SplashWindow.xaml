<Window x:Class="Vetcare.Presentacion.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SplashWindow" Height="400" Width="700"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent">

    <Border Background="White" CornerRadius="20" BorderBrush="#EEEEEE" BorderThickness="1">
        <Grid>
            <Image HorizontalAlignment="Center" Height="133" Margin="0,100,0,0" 
                   VerticalAlignment="Top" Width="504" 
                   Source="/Resources/logo2-transparente.png"/>

            <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,80" HorizontalAlignment="Center">
                <TextBlock x:Name="lblEstado" Text="Iniciando aplicación..." 
                           HorizontalAlignment="Center" FontSize="16" Foreground="#555555"/>

                <Ellipse Margin="0,20,0,0" Width="30" Height="30" 
                         Stroke="#3498db" StrokeThickness="4" 
                         StrokeDashArray="2 1" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="noFreeze" Angle="0" />
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="noFreeze" 
                                                     Storyboard.TargetProperty="Angle" 
                                                     From="0" To="360" Duration="0:0:1" 
                                                     RepeatBehavior="Forever" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
            </StackPanel>
        </Grid>
    </Border>
</Window>