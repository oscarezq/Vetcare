<Page x:Class="Vetcare.Presentacion.Inicio.PageInicio"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1100">

    <!-- Recursos de la página -->
    <Page.Resources>

        <!-- ESTILO DE BOTONES ORIGINAL -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CABECERAS ORIGINALES DEL DATAGRID -->
        <Style x:Key="HeaderStyleOriginal" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8F9F9"/>
            <Setter Property="Foreground" Value="#566573"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="15,0,10,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="#E67E22"/>
        </Style>

        <!-- ESTILO DE FILAS DEL DATAGRID -->
        <Style x:Key="DataGridRowStyleOriginal" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#EBEDEF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F4F6F7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ESTILO DE CELDAS DEL DATAGRID -->
        <Style x:Key="CellStyleOriginal" TargetType="DataGridCell">
            <Setter Property="Padding" Value="15,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Page.Resources>

    <!-- Contenedor principal de la página -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. BLOQUE DE INDICADORES -->
        <UniformGrid x:Name="gridIndicadores" Grid.Row="0" Columns="4" Margin="0,0,0,15">

            <!-- Indicador de clientes -->
            <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,5,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="CLIENTES" FontSize="10" Foreground="#7F8C8D" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalClientes" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                </StackPanel>
            </Border>

            <!-- Indicador de mascotas -->
            <Border Background="White" CornerRadius="10" Padding="15" Margin="5,0,5,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="MASCOTAS" FontSize="10" Foreground="#7F8C8D" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalMascotas" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                </StackPanel>
            </Border>

            <!-- Indicador de citas -->
            <Border Background="White" CornerRadius="10" Padding="15" Margin="5,0,5,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="CITAS HOY" FontSize="10" Foreground="#7F8C8D" FontWeight="Bold"/>
                    <TextBlock x:Name="txtCitasHoy" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2E86C1"/>
                </StackPanel>
            </Border>

            <!-- Indicador de ingresos -->
            <Border x:Name="brdIngresos" Background="White" CornerRadius="10" Padding="15" Margin="5,0,0,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="INGRESOS MES" FontSize="10" Foreground="#7F8C8D" FontWeight="Bold"/>
                    <TextBlock x:Name="txtIngresosHoy" Text="0.00 €" FontSize="24" FontWeight="Bold" Foreground="#27AE60"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- 2. BLOQUE DE ACCESOS RÁPIDOS -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderBrush="#D5DBDB" BorderThickness="1">

            <StackPanel>

                <!-- Título de sección -->
                <TextBlock Text="ACCESOS RÁPIDOS" FontSize="12" FontWeight="Bold" Foreground="#1E293B" Margin="5,0,0,10"/>

                <!-- Grid de botones rápidos -->
                <UniformGrid x:Name="gridBotones" Columns="4">

                    <!-- Botón nueva cita -->
                    <Button x:Name="btnNuevaCita" Content="+ Nueva Cita" Style="{StaticResource ActionButtonStyle}" Background="#3498DB" Click="BtnNuevaCita_Click"/>

                    <!-- Botón nueva mascota -->
                    <Button x:Name="btnNuevaMascota" Content="+ Nueva Mascota" Style="{StaticResource ActionButtonStyle}" Background="#27AE60" Click="BtnNuevaMascota_Click"/>

                    <!-- Botón nuevo cliente -->
                    <Button x:Name="btnNuevoCliente" Content="+ Nuevo Cliente" Style="{StaticResource ActionButtonStyle}" Background="#8E44AD" Click="BtnNuevoCliente_Click"/>

                    <!-- Botón nueva factura -->
                    <Button x:Name="btnAccesoFactura" Content="+ Nueva Factura" Style="{StaticResource ActionButtonStyle}" Background="#F39C12" Click="BtnNuevaFactura_Click"/>

                    <!-- Botón nuevo producto (oculto por defecto) -->
                    <Button x:Name="btnNuevoProducto" Content="+ Nuevo Producto" Visibility="Collapsed" Style="{StaticResource ActionButtonStyle}" Background="#E67E22" Click="BtnNuevoProducto_Click"/>

                    <!-- Botón nuevo servicio (oculto por defecto) -->
                    <Button x:Name="btnNuevoServicio" Content="+ Nuevo Servicio" Visibility="Collapsed" Style="{StaticResource ActionButtonStyle}" Background="#16A085" Click="BtnNuevoServicio_Click"/>

                </UniformGrid>

            </StackPanel>

        </Border>

        <!-- 3. BLOQUE DE TABLAS -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="colFacturas" Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- AGENDA DEL DÍA -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,10,0" BorderBrush="#D5DBDB" BorderThickness="1">

                <Grid>

                    <!-- Filas internas -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Título agenda -->
                    <TextBlock x:Name="txtTituloAgenda" Text="Agenda del Día" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                    <!-- Mensaje cuando no hay citas -->
                    <StackPanel x:Name="pnlSinCitas" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="📅" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="No hay citas programadas para hoy" Foreground="#7F8C8D" FontSize="14" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Tabla de citas -->
                    <DataGrid x:Name="dgCitas" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                              GridLinesVisibility="None" BorderThickness="0" HeadersVisibility="Column" 
                              Background="White" FontSize="14" RowHeight="50" ColumnHeaderHeight="40"
                              RowStyle="{StaticResource DataGridRowStyleOriginal}"
                              ColumnHeaderStyle="{StaticResource HeaderStyleOriginal}"
                              CellStyle="{StaticResource CellStyleOriginal}">

                        <DataGrid.Columns>

                            <!-- Hora de la cita -->
                            <DataGridTextColumn Header="HORA" Binding="{Binding FechaHora, StringFormat=\{0:HH:mm\}}" Width="70" FontWeight="Bold"/>

                            <!-- Cliente -->
                            <DataGridTextColumn Header="CLIENTE" Binding="{Binding NombreDueno}" Width="*"/>

                            <!-- Botón ver detalles -->
                            <DataGridTemplateColumn Header="DETALLES" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Ver Cita" Click="BtnVerConsulta_Click" Background="#EBF5FB" Foreground="#2E86C1" FontWeight="Bold" FontSize="11" Height="28"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

            <!-- FACTURAS PENDIENTES -->
            <Border x:Name="brdFacturas" Grid.Column="1" Background="White" CornerRadius="10" Padding="15" BorderBrush="#D5DBDB" BorderThickness="1">

                <Grid>

                    <!-- Filas internas -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Título facturas -->
                    <TextBlock Text="Pendientes de Cobro" FontSize="20" FontWeight="Bold" Foreground="#E74C3C" Margin="0,0,0,15"/>

                    <!-- Mensaje cuando no hay facturas -->
                    <StackPanel x:Name="pnlSinFacturas" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="✅" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="¡Todo al día! No hay cobros pendientes" Foreground="#7F8C8D" FontSize="14" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Tabla de facturas pendientes -->
                    <DataGrid x:Name="dgFacturasPendientes" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                              GridLinesVisibility="None" BorderThickness="0" HeadersVisibility="Column" 
                              Background="White" FontSize="14" RowHeight="50" ColumnHeaderHeight="40"
                              RowStyle="{StaticResource DataGridRowStyleOriginal}"
                              ColumnHeaderStyle="{StaticResource HeaderStyleOriginal}"
                              CellStyle="{StaticResource CellStyleOriginal}">

                        <DataGrid.Columns>

                            <!-- Cliente -->
                            <DataGridTextColumn Header="CLIENTE" Binding="{Binding NombreApellidosCliente}" Width="*"/>

                            <!-- Total -->
                            <DataGridTextColumn Header="TOTAL" Binding="{Binding Total, StringFormat={}{0:N2} €}" Width="90" FontWeight="Bold"/>

                            <!-- Acción -->
                            <DataGridTemplateColumn Header="ACCIÓN" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Ver Factura" Click="BtnVerFactura_Click" Background="#FDEDEC" Foreground="#C0392B" FontWeight="Bold" FontSize="11" Height="28"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Page>