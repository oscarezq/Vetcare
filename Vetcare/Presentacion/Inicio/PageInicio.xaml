<Page x:Class="Vetcare.Presentacion.Inicio.PageInicio"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1100">

    <Page.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderBrush="#D5DBDB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="ACCESOS RÁPIDOS" FontSize="12" FontWeight="Bold" Foreground="#1E293B" Margin="5,0,0,10"/>
                <UniformGrid Columns="4">
                    <Button Content="+ Nueva Cita" Style="{StaticResource ActionButtonStyle}" Background="#3498DB" Click="btnNuevaCita_Click"/>
                    <Button Content="+ Nueva Mascota" Style="{StaticResource ActionButtonStyle}" Background="#27AE60" Click="btnNuevaMascota_Click"/>
                    <Button Content="+ Nuevo Cliente" Style="{StaticResource ActionButtonStyle}" Background="#8E44AD" Click="btnNuevoCliente_Click"/>
                    <Button Content="+ Nueva Factura" Style="{StaticResource ActionButtonStyle}" Background="#F39C12" Click="btnNuevaFactura_Click"/>
                </UniformGrid>
            </StackPanel>
        </Border>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,15">
            <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,5,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="CLIENTES" FontSize="10" Foreground="#7F8C8D" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalClientes" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="15" Margin="5,0,5,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="MASCOTAS" FontSize="10" Foreground="#7F8C8D" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalMascotas" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="15" Margin="5,0,5,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="CITAS HOY" FontSize="10" Foreground="#7F8C8D" FontWeight="Bold"/>
                    <TextBlock x:Name="txtCitasHoy" Text="0" FontSize="24" FontWeight="Bold" Foreground="#E67E22"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="15" Margin="5,0,0,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="INGRESOS MES" FontSize="10" Foreground="#7F8C8D" FontWeight="Bold"/>
                    <TextBlock x:Name="txtIngresosHoy" Text="0.00 €" FontSize="24" FontWeight="Bold" Foreground="#27AE60"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="15" BorderBrush="#D5DBDB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Agenda del Día" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                <Grid Grid.Row="1">
                    <DataGrid x:Name="dgCitas" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="None" BorderThickness="0" HeadersVisibility="Column" 
                              Background="White" FontSize="14" RowHeight="50" ColumnHeaderHeight="40" SelectionMode="Single" SelectionUnit="FullRow" CanUserSortColumns="False" CanUserReorderColumns="False">
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black" />

                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8F9F9"/>
                                <Setter Property="Foreground" Value="#566573"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="15,0,10,0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter Property="BorderBrush" Value="#E67E22"/>
                            </Style>

                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="15,0,10,0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="#EBEDEF"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F4F6F7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="HORA" Binding="{Binding FechaHora, StringFormat=\{0:HH:mm\}}" Width="100" FontWeight="Bold"/>

                            <DataGridTextColumn Header="CLIENTE" Binding="{Binding NombreDueno}" Width="1.5*"/>

                            <DataGridTextColumn Header="MOTIVO" Binding="{Binding Motivo}" Width="2*"/>

                            <DataGridTextColumn Header="ESTADO" Binding="{Binding Estado}" Width="*"/>

                            <DataGridTemplateColumn Header="DETALLES" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Ver Consulta" 
                                                Click="btnVerConsulta_Click"
                                                Background="#EBF5FB" 
                                                Foreground="#2E86C1" 
                                                FontWeight="Bold" 
                                                FontSize="12"
                                                Padding="10,0"
                                                Height="30" 
                                                Cursor="Hand" 
                                                BorderBrush="#AED6F1" 
                                                BorderThickness="1">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel x:Name="pnlSinCitas" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="📅" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="#BDC3C7"/>
                        <TextBlock Text="No hay citas programadas para hoy" FontSize="16" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                        <TextBlock Text="Relájate o usa los accesos rápidos para crear una." FontSize="12" Foreground="#95A5A6" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>