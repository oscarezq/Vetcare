<Page x:Class="Vetcare.Presentacion.Inicio.PageInicio"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F2F4F4"> <Page.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderBrush="#D5DBDB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="ACCESOS RÁPIDOS" FontSize="12" FontWeight="Bold" Foreground="#1E293B" Margin="5,0,0,10"/>
                <UniformGrid Columns="4">
                    <Button Content="+ Nueva Cita" Style="{StaticResource ActionButtonStyle}" Background="#3498DB" Click="btnNuevaCita_Click"/>
                    <Button Content="+ Nueva Mascota" Style="{StaticResource ActionButtonStyle}" Background="#27AE60" Click="btnNuevaMascota_Click"/>
                    <Button Content="+ Nuevo Cliente" Style="{StaticResource ActionButtonStyle}" Background="#8E44AD" Click="btnNuevoCliente_Click"/>
                    <Button Content="Nueva Factura" Style="{StaticResource ActionButtonStyle}" Background="#F39C12" Click="btnNuevaFactura_Click"/>
                </UniformGrid>
            </StackPanel>
        </Border>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,15">
            <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,5,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="CLIENTES" FontSize="10" Foreground="#7F8C8D" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalClientes" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="15" Margin="5,0,5,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="MASCOTAS" FontSize="10" Foreground="#7F8C8D" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalMascotas" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="15" Margin="5,0,5,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="CITAS HOY" FontSize="10" Foreground="#7F8C8D" FontWeight="Bold"/>
                    <TextBlock x:Name="txtCitasHoy" Text="0" FontSize="24" FontWeight="Bold" Foreground="#E67E22"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="15" Margin="5,0,0,0" BorderBrush="#D5DBDB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="INGRESOS MES" FontSize="10" Foreground="#7F8C8D" FontWeight="Bold"/>
                    <TextBlock x:Name="txtIngresosHoy" Text="0.00 €" FontSize="24" FontWeight="Bold" Foreground="#27AE60"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="15" BorderBrush="#D5DBDB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Agenda del Día" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                <DataGrid x:Name="dgCitas" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="None" BorderThickness="0" HeadersVisibility="Column"
                          Background="White" FontSize="13" RowHeight="45" ColumnHeaderHeight="40">

                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#EBF5FB"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#2E86C1"/>
                        
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9F9"/>
                            <Setter Property="Foreground" Value="#566573"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="15,0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="15,0" Background="Transparent">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="BorderBrush" Value="#EBEDEF"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F4F6F7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="HORA" Binding="{Binding FechaHora, StringFormat=\{0:HH:mm\}}" Width="100"/>
                        <DataGridTemplateColumn Header="PACIENTE" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NombreMascota}" FontWeight="SemiBold" Foreground="#2E86C1" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="PROPIETARIO" Binding="{Binding NombreDueno}" Width="200"/>
                        <DataGridTextColumn Header="MOTIVO" Binding="{Binding Motivo}" Width="*"/>
                        <DataGridTemplateColumn Header="ESTADO" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="brdEstado" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                        <TextBlock x:Name="txtEstado" Text="{Binding Estado}" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                            <Setter TargetName="brdEstado" Property="Background" Value="#FEF9E7"/>
                                            <Setter TargetName="txtEstado" Property="Foreground" Value="#F1C40F"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Estado}" Value="Completada">
                                            <Setter TargetName="brdEstado" Property="Background" Value="#EAFAF1"/>
                                            <Setter TargetName="txtEstado" Property="Foreground" Value="#27AE60"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Estado}" Value="Cancelada">
                                            <Setter TargetName="brdEstado" Property="Background" Value="#FDEDEC"/>
                                            <Setter TargetName="txtEstado" Property="Foreground" Value="#E74C3C"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>